---
---

<section class="py-28 lg:py-40 bg-[#F5F0E6] relative overflow-hidden">
  <!-- Sophisticated grid pattern -->
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(#D4A853 1px, transparent 1px), linear-gradient(90deg, #D4A853 1px, transparent 1px); background-size: 80px 80px;"></div>

  <!-- Dynamic ambient glows -->
  <div class="absolute top-0 right-0 w-[900px] h-[900px] bg-[#D4A853]/6 rounded-full blur-[220px]"></div>
  <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-[#B8923E]/5 rounded-full blur-[180px]"></div>

  <div class="relative max-w-[1600px] mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-20 lg:gap-28 items-center">
      <!-- Text Content -->
      <div class="space-y-10 reveal">
        <!-- Label with premium styling -->
        <div class="inline-flex items-center gap-4">
          <div class="w-14 h-[2px] bg-gradient-to-r from-[#D4A853] to-transparent"></div>
          <span class="text-[#B8923E] text-sm font-semibold tracking-[0.35em] uppercase font-['Space_Grotesk']">About Us</span>
        </div>

        <!-- Heading with gradient accent -->
        <h2 class="font-['Space_Grotesk'] text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold text-[#1A1A2E] leading-[1.08] tracking-tight">
          Architects of
          <span class="relative inline-block">
            <span class="bg-gradient-to-r from-[#D4A853] via-[#C9993D] to-[#B8923E] bg-clip-text text-transparent"> Ambition</span>
            <span class="absolute -bottom-3 left-0 w-full h-[4px] bg-gradient-to-r from-[#D4A853]/60 via-[#D4A853] to-transparent rounded-full"></span>
          </span>
        </h2>

        <!-- Refined paragraphs -->
        <p class="text-[#1A1A2E]/65 text-lg lg:text-xl leading-[1.8] max-w-xl">
          That's who we are. Welcome to Punjab Angels, India's foremost platform dedicated to cultivating an startup ecosystem. We are more than just an investment network; we are architects of ambition, fostering a community where passionate founders thrive.
        </p>

        <p class="text-[#1A1A2E]/45 leading-relaxed max-w-xl">
          At Punjab Angels, we're not just building businesses; we're building a future. We take pride in nurturing visionary founders, equipping them with a profound understanding of venture investing as a powerful asset class. Our commitment extends beyond funding; we're here to create platforms where both founders and investors embark on a journey of learning, investing, and unparalleled growth.
        </p>

        <!-- CTA with premium styling -->
        <a
          href="/contact"
          class="group inline-flex items-center gap-3 text-[#B8923E] font-semibold hover:text-[#D4A853] transition-colors duration-300"
        >
          <span class="relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-[2px] after:bg-[#D4A853] after:transition-all after:duration-300 group-hover:after:w-full">Talk With Us</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-2 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Visual Block with premium design -->
      <div class="reveal" style="animation-delay: 200ms;">
        <div class="relative">
          <!-- Main card with glassmorphism -->
          <div class="relative bg-white/90 backdrop-blur-xl rounded-3xl p-10 lg:p-12 shadow-[0_0_60px_rgba(212,168,83,0.1)] border border-[#D4A853]/10 overflow-hidden">
            <!-- Inner glow -->
            <div class="absolute inset-0 bg-gradient-to-br from-[#D4A853]/5 via-transparent to-[#B8923E]/5 rounded-3xl"></div>

            <!-- Stats grid -->
            <div class="relative grid grid-cols-2 gap-6">
              <div class="text-center p-6 bg-[#F5F0E6]/80 rounded-2xl border border-[#D4A853]/10 hover:border-[#D4A853]/30 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 group">
                <span class="font-['Space_Grotesk'] text-4xl lg:text-5xl xl:text-6xl font-bold bg-gradient-to-r from-[#D4A853] to-[#B8923E] bg-clip-text text-transparent group-hover:scale-105 transition-transform duration-300">50+</span>
                <p class="text-[#1A1A2E]/50 mt-3 text-sm font-medium">Startups Funded</p>
              </div>
              <div class="text-center p-6 bg-[#F5F0E6]/80 rounded-2xl border border-[#D4A853]/10 hover:border-[#D4A853]/30 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 group">
                <span class="font-['Space_Grotesk'] text-4xl lg:text-5xl xl:text-6xl font-bold bg-gradient-to-r from-[#D4A853] to-[#B8923E] bg-clip-text text-transparent group-hover:scale-105 transition-transform duration-300">100+</span>
                <p class="text-[#1A1A2E]/50 mt-3 text-sm font-medium">Investors</p>
              </div>
              <div class="text-center p-6 bg-[#F5F0E6]/80 rounded-2xl border border-[#D4A853]/10 hover:border-[#D4A853]/30 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 group">
                <span class="font-['Space_Grotesk'] text-4xl lg:text-5xl xl:text-6xl font-bold bg-gradient-to-r from-[#D4A853] to-[#B8923E] bg-clip-text text-transparent group-hover:scale-105 transition-transform duration-300">12+</span>
                <p class="text-[#1A1A2E]/50 mt-3 text-sm font-medium">Partners</p>
              </div>
              <div class="text-center p-6 bg-[#F5F0E6]/80 rounded-2xl border border-[#D4A853]/10 hover:border-[#D4A853]/30 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 group">
                <span class="font-['Space_Grotesk'] text-4xl lg:text-5xl xl:text-6xl font-bold bg-gradient-to-r from-[#D4A853] to-[#B8923E] bg-clip-text text-transparent group-hover:scale-105 transition-transform duration-300">20+</span>
                <p class="text-[#1A1A2E]/50 mt-3 text-sm font-medium">Events Yearly</p>
              </div>
            </div>
          </div>

          <!-- Decorative floating elements -->
          <div class="absolute -top-8 -right-8 w-40 h-40 bg-[#D4A853]/8 rounded-full blur-3xl"></div>
          <div class="absolute -bottom-10 -left-10 w-52 h-52 bg-[#B8923E]/5 rounded-full blur-3xl"></div>

          <!-- Corner accents -->
          <div class="absolute -top-3 -right-3 w-6 h-6 border-t-2 border-r-2 border-[#D4A853]/40 rounded-tr-xl"></div>
          <div class="absolute -bottom-3 -left-3 w-6 h-6 border-b-2 border-l-2 border-[#D4A853]/40 rounded-bl-xl"></div>

          <!-- Additional decorative dots -->
          <div class="absolute -top-6 left-10 w-2 h-2 bg-[#D4A853]/40 rounded-full"></div>
          <div class="absolute -right-4 top-1/3 w-3 h-3 bg-[#D4A853]/30 rounded-full"></div>
          <div class="absolute -left-6 bottom-1/4 w-2 h-2 bg-[#B8923E]/30 rounded-full"></div>
        </div>
      </div>
    </div>
  </div>
</section>