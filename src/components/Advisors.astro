---
const advisors = [
  { name: "Mr. Ramanan Ramanathan" },
  { name: "Mr. Raman Bhalla" },
  { name: "Mr. Iqbal Singh" },
  { name: "Mr. Vivek Attray" },
  { name: "Mr. Atul Mehta" },
  { name: "Dr. Srinivasan Iyengar" },
  { name: "Mr. Dilbir Singh" },
  { name: "Mr. Atul Gupta" },
  { name: "Mr. Avinash Nichkawde" },
  { name: "Ms. Anuradha Chawla" },
  { name: "Mr. Sumit Singh" },
  { name: "Mr. Deepak Kumar" },
];
---

<section class="py-32 lg:py-48 bg-[#E8E4DF] relative overflow-hidden">
  <!-- Subtle texture -->
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(#B8963E 1px, transparent 1px), linear-gradient(90deg, #B8963E 1px, transparent 1px); background-size: 100px 100px;"></div>

  <!-- Ambient glows -->
  <div class="absolute top-0 left-1/4 w-[700px] h-[700px] bg-[#B8963E]/5 rounded-full blur-[200px]"></div>

  <div class="relative max-w-[1600px] mx-auto px-8 lg:px-16">
    <!-- Section header - Centered editorial -->
    <div class="text-center mb-20 reveal">
      <div class="flex items-center justify-center gap-4 mb-8">
        <div class="w-16 h-[1px] bg-gradient-to-r from-transparent to-[#B8963E]"></div>
        <span class="text-[#B8963E] text-xs font-['Jost'] font-medium tracking-[0.3em] uppercase">Advisory Board</span>
        <div class="w-16 h-[1px] bg-gradient-to-l from-transparent to-[#B8963E]"></div>
      </div>
      <h2 class="font-['Bodoni_Moda'] text-4xl lg:text-5xl xl:text-6xl font-medium text-[#1A1817] mb-6">
        Board of <span class="text-gold-gradient">Advisors</span>
      </h2>
      <p class="text-[#1A1817]/50 mt-4 max-w-2xl mx-auto text-lg font-['Jost'] font-light">
        The masterminds of the Business World. Our Eminent Board of advisor constitutes brilliant minds from distinct domains with years of experience.
      </p>
    </div>

    <!-- Advisors grid with premium cards -->
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-5 lg:gap-7">
      {advisors.map((advisor, index) => (
        <div
          class="group text-center reveal"
          style={`animation-delay: ${index * 50}ms;`}
        >
          <!-- Avatar card with glassmorphism -->
          <div class="relative aspect-square bg-white/90 backdrop-blur-xl rounded-3xl flex items-center justify-center mb-4 border border-[#1A1817]/5 group-hover:border-[#B8963E]/30 transition-all duration-500 group-hover:shadow-luxe-sm group-hover:-translate-y-2 overflow-hidden">
            <!-- Inner gradient glow on hover -->
            <div class="absolute inset-0 bg-gradient-to-br from-[#B8963E]/10 via-transparent to-[#96751C]/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

            <!-- Decorative corner -->
            <div class="absolute top-0 right-0 w-12 h-12 bg-gradient-to-bl from-[#B8963E]/10 to-transparent rounded-full -translate-y-6 translate-x-6 group-hover:from-[#B8963E]/20 transition-all duration-500"></div>

            <div class="relative w-full h-full bg-gradient-to-br from-[#B8963E]/8 to-transparent flex items-center justify-center rounded-3xl">
              <span class="font-['Bodoni_Moda'] text-2xl lg:text-3xl font-medium bg-gradient-to-r from-[#B8963E] to-[#96751C] bg-clip-text text-transparent group-hover:scale-110 transition-transform duration-500">
                {advisor.name.split(' ').map(n => n[0]).slice(0, 2).join('')}
              </span>
            </div>
          </div>

          <!-- Name -->
          <p class="text-sm font-['Jost'] font-light text-[#1A1817]/60 group-hover:text-[#B8963E] transition-colors duration-300 leading-tight px-1">
            {advisor.name.replace('Mr. ', '').replace('Ms. ', '')}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>