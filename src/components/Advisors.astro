---
const advisors = [
  { name: "Mr. Ramanan Ramanathan" },
  { name: "Mr. Raman Bhalla" },
  { name: "Mr. Iqbal Singh" },
  { name: "Mr. Vivek Attray" },
  { name: "Mr. Atul Mehta" },
  { name: "Dr. Srinivasan Iyengar" },
  { name: "Mr. Dilbir Singh" },
  { name: "Mr. Atul Gupta" },
  { name: "Mr. Avinash Nichkawde" },
  { name: "Ms. Anuradha Chawla" },
  { name: "Mr. Sumit Singh" },
  { name: "Mr. Deepak Kumar" },
];
---

<section class="py-24 lg:py-32 bg-[#111113] relative overflow-hidden">
  <!-- Subtle grid pattern -->
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(#D4A853 1px, transparent 1px), linear-gradient(90deg, #D4A853 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- Ambient glow -->
  <div class="absolute top-0 left-1/4 w-[600px] h-[600px] bg-[#D4A853]/4 rounded-full blur-[180px]"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <div class="inline-flex items-center gap-3 mb-6">
        <div class="w-12 h-[1px] bg-[#D4A853]"></div>
        <span class="text-[#D4A853] text-sm font-medium tracking-[0.3em] uppercase font-['Space_Grotesk']">Advisory Board</span>
        <div class="w-12 h-[1px] bg-[#D4A853]"></div>
      </div>
      <h2 class="font-['Space_Grotesk'] text-4xl lg:text-5xl xl:text-6xl font-bold text-white mb-4">
        Board of
        <span class="bg-gradient-to-r from-[#D4A853] via-[#E8C47C] to-[#D4A853] bg-clip-text text-transparent"> Advisors</span>
      </h2>
      <p class="text-white/50 mt-4 max-w-2xl mx-auto">
        The masterminds of the Business World. Our Eminent Board of advisor constitutes brilliant minds from distinct domains with years of experience.
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 lg:gap-6">
      {advisors.map((advisor, index) => (
        <div
          class="group text-center reveal"
          style={`animation-delay: ${index * 50}ms;`}
        >
          <div class="aspect-square bg-gradient-to-br from-[#1A1A1C] to-[#252528] rounded-2xl flex items-center justify-center mb-3 group-hover:scale-105 group-hover:border-[#D4A853]/30 border border-transparent transition-all duration-300 overflow-hidden">
            <div class="w-full h-full bg-gradient-to-br from-[#D4A853]/10 to-transparent flex items-center justify-center">
              <span class="font-['Space_Grotesk'] text-2xl lg:text-3xl font-bold bg-gradient-to-r from-[#D4A853] to-[#E8C47C] bg-clip-text text-transparent">
                {advisor.name.split(' ').map(n => n[0]).slice(0, 2).join('')}
              </span>
            </div>
          </div>
          <p class="text-sm font-medium text-white/70 group-hover:text-[#D4A853] transition-colors duration-300">
            {advisor.name.replace('Mr. ', '').replace('Ms. ', '')}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
