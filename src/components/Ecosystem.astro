---
const ecosystem = [
  {
    icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
    title: "Corporates",
    description: "Support system for the ecosystem, aspirations for IPO"
  },
  {
    icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    title: "Investors",
    description: "Boosting entrepreneurship and economic growth"
  },
  {
    icon: "M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z",
    title: "Academia",
    description: "Research partner, Creating talent in the region"
  }
];
---

<section class="py-32 lg:py-48 bg-[#E8E4DF] relative overflow-hidden">
  <!-- Subtle texture -->
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(#B8963E 1px, transparent 1px), linear-gradient(90deg, #B8963E 1px, transparent 1px); background-size: 100px 100px;"></div>

  <!-- Ambient glows -->
  <div class="absolute top-1/3 left-0 w-[700px] h-[700px] bg-[#B8963E]/5 rounded-full blur-[200px]"></div>

  <div class="relative max-w-[1600px] mx-auto px-8 lg:px-16">
    <!-- Section header - Centered editorial -->
    <div class="text-center mb-20 reveal">
      <div class="flex items-center justify-center gap-4 mb-8">
        <div class="w-16 h-[1px] bg-gradient-to-r from-transparent to-[#B8963E]"></div>
        <span class="text-[#B8963E] text-xs font-['Jost'] font-medium tracking-[0.3em] uppercase">Ecosystem</span>
        <div class="w-16 h-[1px] bg-gradient-to-l from-transparent to-[#B8963E]"></div>
      </div>
      <h2 class="font-['Bodoni_Moda'] text-4xl lg:text-5xl xl:text-6xl font-medium text-[#1A1817] mb-6">
        Building <span class="text-gold-gradient">Entrepreneurship</span> Ecosystem
      </h2>
    </div>

    <!-- Ecosystem cards with premium styling -->
    <div class="grid md:grid-cols-3 gap-8 lg:gap-10">
      {ecosystem.map((item, index) => (
        <div
          class="group relative bg-white/90 backdrop-blur-xl rounded-3xl p-10 lg:p-12 border border-[#1A1817]/5 hover:border-[#B8963E]/30 transition-all duration-500 reveal hover:shadow-luxe hover:-translate-y-3 text-center overflow-hidden"
          style={`animation-delay: ${index * 150}ms;`}
        >
          <!-- Inner gradient glow -->
          <div class="absolute inset-0 bg-gradient-to-br from-[#B8963E]/5 via-transparent to-[#96751C]/5 rounded-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <!-- Decorative corner -->
          <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl from-[#B8963E]/10 to-transparent rounded-full -translate-y-16 translate-x-16 group-hover:from-[#B8963E]/20 transition-all duration-500"></div>

          <!-- Icon -->
          <div class="relative w-20 h-20 bg-gradient-to-br from-[#B8963E]/15 via-[#B8963E]/10 to-transparent rounded-3xl flex items-center justify-center mx-auto mb-8 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-[#B8963E] group-hover:text-[#D4A853] transition-colors duration-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d={item.icon}/>
            </svg>
          </div>

          <!-- Title -->
          <h3 class="relative font-['Bodoni_Moda'] text-2xl lg:text-3xl font-medium text-[#1A1817] mb-5 group-hover:text-[#B8963E] transition-colors duration-300">{item.title}</h3>

          <!-- Description -->
          <p class="relative text-[#1A1817]/50 mb-8 leading-relaxed font-['Jost'] font-light">{item.description}</p>

          <!-- CTA -->
          <a
            href="#"
            class="relative inline-flex items-center gap-2.5 text-[#B8963E] font-['Jost'] font-medium group-hover:text-[#D4A853] transition-colors duration-300 hover-underline"
          >
            <span>Learn More</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-2 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-20 reveal">
      <a
        href="/contact"
        class="group inline-flex items-center gap-3 px-10 py-5 bg-[#1A1817] text-white font-['Jost'] font-medium rounded-full hover:shadow-luxe transition-all duration-500 hover:-translate-y-1"
      >
        <span>Talk With Us</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>