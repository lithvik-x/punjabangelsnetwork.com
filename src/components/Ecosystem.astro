---
const ecosystem = [
  {
    icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
    title: "Corporates",
    description: "Support system for the ecosystem, aspirations for IPO"
  },
  {
    icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    title: "Investors",
    description: "Boosting entrepreneurship and economic growth"
  },
  {
    icon: "M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z",
    title: "Academia",
    description: "Research partner, Creating talent in the region"
  }
];
---

<section class="py-28 lg:py-40 bg-[#EBE4D6] relative overflow-hidden">
  <!-- Sophisticated grid pattern -->
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(#D4A853 1px, transparent 1px), linear-gradient(90deg, #D4A853 1px, transparent 1px); background-size: 80px 80px;"></div>

  <!-- Ambient glows -->
  <div class="absolute top-1/3 left-0 w-[700px] h-[700px] bg-[#D4A853]/6 rounded-full blur-[200px]"></div>
  <div class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-[#B8923E]/5 rounded-full blur-[150px]"></div>

  <div class="relative max-w-[1600px] mx-auto px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-20 reveal">
      <div class="inline-flex items-center gap-4 mb-8">
        <div class="w-14 h-[2px] bg-gradient-to-r from-transparent to-[#D4A853]"></div>
        <span class="text-[#B8923E] text-sm font-semibold tracking-[0.35em] uppercase font-['Space_Grotesk']">Ecosystem</span>
        <div class="w-14 h-[2px] bg-gradient-to-l from-transparent to-[#D4A853]"></div>
      </div>
      <h2 class="font-['Space_Grotesk'] text-4xl lg:text-5xl xl:text-6xl font-bold text-[#1A1A2E] mb-6">
        Building
        <span class="bg-gradient-to-r from-[#D4A853] via-[#C9993D] to-[#B8923E] bg-clip-text text-transparent"> Entrepreneurship</span> Ecosystem
      </h2>
    </div>

    <!-- Ecosystem cards with premium styling -->
    <div class="grid md:grid-cols-3 gap-8 lg:gap-10">
      {ecosystem.map((item, index) => (
        <div
          class="group relative bg-white/90 backdrop-blur-xl rounded-[2rem] p-10 lg:p-12 border border-[#D4A853]/10 hover:border-[#D4A853]/30 transition-all duration-500 reveal hover:shadow-[0_0_60px_rgba(212,168,83,0.15)] hover:-translate-y-3 text-center overflow-hidden"
          style={`animation-delay: ${index * 150}ms;`}
        >
          <!-- Inner gradient glow -->
          <div class="absolute inset-0 bg-gradient-to-br from-[#D4A853]/5 via-transparent to-[#B8923E]/5 rounded-[2rem] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <!-- Decorative corner -->
          <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl from-[#D4A853]/10 to-transparent rounded-full -translate-y-16 translate-x-16 group-hover:from-[#D4A853]/20 transition-all duration-500"></div>

          <!-- Icon -->
          <div class="relative w-22 h-22 bg-gradient-to-br from-[#D4A853]/15 via-[#D4A853]/10 to-transparent rounded-3xl flex items-center justify-center mx-auto mb-8 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-11 h-11 text-[#B8923E] group-hover:text-[#D4A853] transition-colors duration-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d={item.icon}/>
            </svg>
          </div>

          <!-- Title -->
          <h3 class="relative font-['Space_Grotesk'] text-2xl lg:text-3xl font-bold text-[#1A1A2E] mb-5 group-hover:text-[#B8923E] transition-colors duration-300">{item.title}</h3>

          <!-- Description -->
          <p class="relative text-[#1A1A2E]/50 mb-8 leading-relaxed">{item.description}</p>

          <!-- CTA -->
          <a
            href="#"
            class="relative inline-flex items-center gap-2.5 text-[#B8923E] font-semibold group-hover:text-[#D4A853] transition-colors duration-300"
          >
            <span class="relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-[2px] after:bg-current after:transition-all after:duration-300 group-hover:after:w-full">Learn More</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-2 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-20 reveal">
      <a
        href="/contact"
        class="group inline-flex items-center gap-3 px-10 py-5 bg-gradient-to-r from-[#D4A853] to-[#B8923E] text-white font-semibold rounded-full hover:shadow-[0_0_50px_rgba(212,168,83,0.45)] transition-all duration-500 hover:-translate-y-1"
      >
        <span>Talk With Us</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>