---
const ecosystem = [
  {
    icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
    title: "Corporates",
    description: "Support system for the ecosystem, aspirations for IPO"
  },
  {
    icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    title: "Investors",
    description: "Boosting entrepreneurship and economic growth"
  },
  {
    icon: "M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z",
    title: "Academia",
    description: "Research partner, Creating talent in the region"
  }
];
---

<section class="py-20 lg:py-32 bg-[#FDFBF7]">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-16 reveal">
      <p class="text-[#D4A853] font-mono text-sm tracking-widest mb-4">ECOSYSTEM</p>
      <h2 class="font-['DM_Serif_Display'] text-4xl lg:text-5xl text-[#1A1A2E]">
        Building <span class="text-gold-gradient">Entrepreneurship</span> Ecosystem
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {ecosystem.map((item, index) => (
        <div
          class="group bg-white rounded-3xl p-8 shadow-sm hover:shadow-xl transition-all duration-500 text-center reveal border-2 border-transparent hover:border-[#D4A853]/30"
          style={`animation-delay: ${index * 150}ms;`}
        >
          <div class="w-20 h-20 bg-gradient-to-br from-[#1A1A2E] to-[#2D2D4A] rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-[#D4A853]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d={item.icon}/>
            </svg>
          </div>
          <h3 class="font-['DM_Serif_Display'] text-2xl text-[#1A1A2E] mb-4">{item.title}</h3>
          <p class="text-[#6B6B6B]">{item.description}</p>
          <a
            href="#"
            class="inline-flex items-center gap-2 mt-6 text-[#D4A853] font-semibold hover:text-[#B8923E] transition-colors"
          >
            Learn More
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>
      ))}
    </div>

    <div class="text-center mt-16 reveal">
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-[#D4A853] to-[#B8923E] text-white font-semibold rounded-full hover:shadow-lg hover:shadow-[#D4A853]/30 transition-all duration-300"
      >
        Talk With Us
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>
