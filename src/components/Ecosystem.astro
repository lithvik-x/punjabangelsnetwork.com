---
const ecosystem = [
  {
    icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
    title: "Corporates",
    description: "Support system for the ecosystem, aspirations for IPO"
  },
  {
    icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    title: "Investors",
    description: "Boosting entrepreneurship and economic growth"
  },
  {
    icon: "M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z",
    title: "Academia",
    description: "Research partner, Creating talent in the region"
  }
];
---

<section class="py-24 lg:py-32 bg-[#EBE4D6] relative overflow-hidden">
  <!-- Subtle grid pattern -->
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(#D4A853 1px, transparent 1px), linear-gradient(90deg, #D4A853 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- Ambient warm glow -->
  <div class="absolute top-1/3 left-0 w-[600px] h-[600px] bg-[#D4A853]/8 rounded-full blur-[180px]"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <div class="inline-flex items-center gap-3 mb-6">
        <div class="w-12 h-[2px] bg-[#D4A853]"></div>
        <span class="text-[#B8923E] text-sm font-medium tracking-[0.3em] uppercase font-['Space_Grotesk']">Ecosystem</span>
        <div class="w-12 h-[2px] bg-[#D4A853]"></div>
      </div>
      <h2 class="font-['Space_Grotesk'] text-4xl lg:text-5xl xl:text-6xl font-bold text-[#1A1A2E] mb-4">
        Building
        <span class="bg-gradient-to-r from-[#D4A853] via-[#C9993D] to-[#B8923E] bg-clip-text text-transparent"> Entrepreneurship</span> Ecosystem
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {ecosystem.map((item, index) => (
        <div
          class="group bg-white rounded-3xl p-8 border border-[#D4A853]/10 hover:border-[#D4A853]/30 transition-all duration-500 text-center reveal hover:shadow-xl"
          style={`animation-delay: ${index * 150}ms;`}
        >
          <div class="w-20 h-20 bg-gradient-to-br from-[#D4A853]/10 to-[#D4A853]/5 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-[#B8923E]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d={item.icon}/>
            </svg>
          </div>
          <h3 class="font-['Space_Grotesk'] text-2xl font-bold text-[#1A1A2E] mb-4">{item.title}</h3>
          <p class="text-[#1A1A2E]/50 mb-6">{item.description}</p>
          <a
            href="#"
            class="inline-flex items-center gap-2 text-[#B8923E] font-medium hover:text-[#D4A853] transition-colors duration-300 group/link"
          >
            <span>Learn More</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover/link:translate-x-1 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>
      ))}
    </div>

    <div class="text-center mt-16 reveal">
      <a
        href="/contact"
        class="group inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-[#D4A853] to-[#B8923E] text-white font-semibold rounded-full hover:shadow-[0_0_40px_rgba(212,168,83,0.4)] transition-all duration-300 hover:-translate-y-0.5"
      >
        <span>Talk With Us</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>
