---
const eventTypes = [
  {
    title: "Weekly Events",
    location: "Tricity",
    places: ["Chandigarh", "Panchkula", "Mohali"]
  },
  {
    title: "Monthly Events",
    location: "Northern India",
    places: ["Ludhiana", "Amritsar", "Gurugram", "Shimla"]
  },
  {
    title: "Quarterly Events",
    location: "Business Hubs of India",
    places: ["Mumbai", "Bengaluru", "Hyderabad"]
  },
  {
    title: "Annual Events",
    location: "Business Hubs of the World",
    places: ["UK", "US", "Canada", "Australia", "South Africa"]
  }
];
---

<section class="py-20 lg:py-32 bg-[#1A1A2E]">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-16 reveal">
      <p class="text-[#D4A853] font-mono text-sm tracking-widest mb-4">NETWORKING</p>
      <h2 class="font-['DM_Serif_Display'] text-4xl lg:text-5xl text-white">
        Join Our <span class="text-gold-gradient">Events Network</span> for Success
      </h2>
      <p class="text-white/70 mt-4">Explore an Insight to our proficiency</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {eventTypes.map((event, index) => (
        <div
          class="bg-white/5 backdrop-blur-sm rounded-2xl p-6 border border-white/10 hover:border-[#D4A853]/50 transition-all duration-300 reveal"
          style={`animation-delay: ${index * 100}ms;`}
        >
          <h3 class="font-['DM_Serif_Display'] text-xl text-[#D4A853] mb-2">{event.title}</h3>
          <p class="text-white/70 text-sm mb-4">{event.location}</p>
          <div class="space-y-2">
            {event.places.map(place => (
              <div class="flex items-center gap-2 text-white/80">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#D4A853]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
                </svg>
                <span class="text-sm">{place}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
