---
const eventTypes = [
  {
    title: "Weekly Events",
    location: "Tricity",
    places: ["Chandigarh", "Panchkula", "Mohali"]
  },
  {
    title: "Monthly Events",
    location: "Northern India",
    places: ["Ludhiana", "Amritsar", "Gurugram", "Shimla"]
  },
  {
    title: "Quarterly Events",
    location: "Business Hubs of India",
    places: ["Mumbai", "Bengaluru", "Hyderabad"]
  },
  {
    title: "Annual Events",
    location: "Business Hubs of the World",
    places: ["UK", "US", "Canada", "Australia", "South Africa"]
  }
];
---

<section class="py-32 lg:py-48 bg-[#FAF8F5] relative overflow-hidden">
  <!-- Subtle texture -->
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(#B8963E 1px, transparent 1px), linear-gradient(90deg, #B8963E 1px, transparent 1px); background-size: 100px 100px;"></div>

  <!-- Ambient glows -->
  <div class="absolute bottom-0 left-1/4 w-[700px] h-[700px] bg-[#B8963E]/5 rounded-full blur-[200px]"></div>

  <div class="relative max-w-[1600px] mx-auto px-8 lg:px-16">
    <!-- Section header - Centered editorial -->
    <div class="text-center mb-20 reveal">
      <div class="flex items-center justify-center gap-4 mb-8">
        <div class="w-16 h-[1px] bg-gradient-to-r from-transparent to-[#B8963E]"></div>
        <span class="text-[#B8963E] text-xs font-['Jost'] font-medium tracking-[0.3em] uppercase">Networking</span>
        <div class="w-16 h-[1px] bg-gradient-to-l from-transparent to-[#B8963E]"></div>
      </div>
      <h2 class="font-['Bodoni_Moda'] text-4xl lg:text-5xl xl:text-6xl font-medium text-[#1A1817] mb-6">
        Join Our <span class="text-gold-gradient">Events Network</span> for Success
      </h2>
      <p class="text-[#1A1817]/50 mt-4 text-lg font-['Jost'] font-light">Explore an Insight to our proficiency</p>
    </div>

    <!-- Event cards with premium styling -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-7">
      {eventTypes.map((event, index) => (
        <div
          class="group relative bg-white/90 backdrop-blur-xl rounded-3xl p-8 border border-[#1A1817]/5 hover:border-[#B8963E]/30 transition-all duration-500 reveal hover:shadow-luxe-sm hover:-translate-y-2 overflow-hidden"
          style={`animation-delay: ${index * 100}ms;`}
        >
          <!-- Inner gradient glow -->
          <div class="absolute inset-0 bg-gradient-to-br from-[#B8963E]/5 via-transparent to-transparent rounded-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <!-- Decorative corner element -->
          <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-bl from-[#B8963E]/10 to-transparent rounded-full -translate-y-10 translate-x-10 group-hover:from-[#B8963E]/20 transition-all duration-500"></div>

          <!-- Content -->
          <div class="relative">
            <!-- Title -->
            <h3 class="font-['Bodoni_Moda'] text-lg lg:text-xl font-medium text-[#B8963E] mb-2 group-hover:text-[#D4A853] transition-colors duration-300">{event.title}</h3>

            <!-- Location -->
            <p class="text-[#1A1817]/40 text-sm mb-6 font-['Jost'] font-light">{event.location}</p>

            <!-- Places list -->
            <div class="space-y-3">
              {event.places.map(place => (
                <div class="flex items-center gap-3 text-[#1A1817]/60 group-hover:text-[#1A1817]/80 transition-colors duration-300">
                  <div class="w-2 h-2 bg-gradient-to-br from-[#B8963E] to-[#96751C] rounded-full flex-shrink-0"></div>
                  <span class="text-sm font-['Jost']">{place}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>