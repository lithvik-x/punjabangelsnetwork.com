---
const navLinks = [
  { name: "Home", href: "/" },
  { name: "About", href: "/about" },
  { name: "Fund Raising", href: "/fund-raising" },
  { name: "Startup", href: "/startup" },
  { name: "Investor", href: "/investors" },
  { name: "Institutional Support", href: "/institutional-support" },
  { name: "Events", href: "/events" },
  { name: "Contact", href: "/contact" },
];

const quickLinks = [
  { name: "Apply Now", href: "/apply" },
  { name: "Investor Enrollment", href: "/investor-enrollment" },
  { name: "Corporate Membership", href: "/corporate-membership-enrollment" },
  { name: "Our Team", href: "/our-team" },
];
---

<footer class="bg-[#0A0A0B] pt-20 pb-8 relative overflow-hidden">
  <!-- Subtle grid pattern -->
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(#D4A853 1px, transparent 1px), linear-gradient(90deg, #D4A853 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- Ambient glow -->
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#D4A853]/3 rounded-full blur-[150px]"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 bg-gradient-to-br from-[#D4A853] to-[#B8923E] rounded-xl flex items-center justify-center shadow-[0_0_30px_rgba(212,168,83,0.2)]">
            <span class="text-white font-bold text-xl font-['Space_Grotesk']">PA</span>
          </div>
          <div>
            <span class="font-['Space_Grotesk'] text-xl font-bold text-white">Punjab Angels</span>
            <span class="block text-xs text-white/40 tracking-wider uppercase">Network</span>
          </div>
        </a>
        <p class="text-white/50 mb-6">
          India's foremost platform dedicated to cultivating an startup ecosystem. We are architects of ambition, fostering a community where passionate founders thrive.
        </p>
        <!-- Social Links -->
        <div class="flex gap-3">
          <a href="https://x.com/PunjabAngelsNW" target="_blank" aria-label="Twitter" class="w-10 h-10 bg-white/5 rounded-full flex items-center justify-center hover:bg-[#D4A853] hover:border-[#D4A853]/40 border border-white/10 transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="https://www.facebook.com/punjabangelsnetwork/" target="_blank" aria-label="Facebook" class="w-10 h-10 bg-white/5 rounded-full flex items-center justify-center hover:bg-[#D4A853] hover:border-[#D4A853]/40 border border-white/10 transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/company/punjabangelsnetwork/" target="_blank" aria-label="LinkedIn" class="w-10 h-10 bg-white/5 rounded-full flex items-center justify-center hover:bg-[#D4A853] hover:border-[#D4A853]/40 border border-white/10 transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/punjabangelsnetwork/" target="_blank" aria-label="Instagram" class="w-10 h-10 bg-white/5 rounded-full flex items-center justify-center hover:bg-[#D4A853] hover:border-[#D4A853]/40 border border-white/10 transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-['Space_Grotesk'] text-lg font-semibold text-white mb-6">Quick Links</h4>
        <ul class="space-y-3">
          {quickLinks.map(link => (
            <li>
              <a href={link.href} class="text-white/50 hover:text-[#D4A853] transition-colors duration-300">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="font-['Space_Grotesk'] text-lg font-semibold text-white mb-6">Navigation</h4>
        <ul class="space-y-3">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class="text-white/50 hover:text-[#D4A853] transition-colors duration-300">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-['Space_Grotesk'] text-lg font-semibold text-white mb-6">Contact</h4>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#D4A853] mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            <span class="text-white/50">C-201-202, Sector 74, Mohali, Punjab</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#D4A853] mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <a href="mailto:info@punjabangelsnetwork.com" class="text-white/50 hover:text-[#D4A853] transition-colors duration-300">
              info@punjabangelsnetwork.com
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-white/5">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
        <p class="text-white/40 text-sm text-center sm:text-left">
          © Copyright 2026 Designed and Developed by
          <a href="https://unifywizards.com/" target="_blank" class="text-[#D4A853] hover:underline">
            Unify Wizards
          </a>
        </p>
      </div>
    </div>
  </div>
</footer>
