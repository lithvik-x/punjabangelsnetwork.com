---
---

<section class="relative min-h-[95vh] flex items-center overflow-hidden bg-[#F5F0E6]">
  <!-- Sophisticated grid pattern -->
  <div class="absolute inset-0 opacity-[0.025]" style="background-image: linear-gradient(#D4A853 1px, transparent 1px), linear-gradient(90deg, #D4A853 1px, transparent 1px); background-size: 80px 80px;"></div>

  <!-- Dynamic ambient glows -->
  <div class="absolute top-1/4 right-1/4 w-[900px] h-[900px] bg-[#D4A853]/8 rounded-full blur-[200px] animate-pulse"></div>
  <div class="absolute bottom-1/4 left-1/3 w-[600px] h-[600px] bg-[#B8923E]/5 rounded-full blur-[150px] animate-pulse" style="animation-delay: 1s;"></div>

  <!-- Gold accent lines -->
  <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#D4A853]/30 to-transparent"></div>
  <div class="absolute bottom-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#D4A853]/20 to-transparent"></div>

  <!-- Floating decorative elements -->
  <div class="absolute top-[15%] left-[5%] w-3 h-3 bg-[#D4A853]/30 rounded-full animate-float"></div>
  <div class="absolute top-[25%] right-[8%] w-2 h-2 bg-[#D4A853]/20 rounded-full animate-float" style="animation-delay: 0.5s;"></div>
  <div class="absolute bottom-[30%] left-[10%] w-4 h-4 bg-[#D4A853]/15 rounded-full animate-float" style="animation-delay: 1s;"></div>
  <div class="absolute top-[40%] right-[15%] w-2 h-2 bg-[#B8923E]/25 rounded-full animate-float" style="animation-delay: 1.5s;"></div>

  <div class="relative max-w-[1600px] mx-auto px-6 lg:px-8 py-24 lg:py-0">
    <div class="grid lg:grid-cols-2 gap-20 items-center">
      <!-- Text Content -->
      <div class="space-y-10">
        <!-- Badge with glow -->
        <div class="inline-flex items-center gap-3 px-6 py-3 bg-white/80 backdrop-blur-sm border border-[#D4A853]/20 rounded-full shadow-[0_0_30px_rgba(212,168,83,0.1)] animate-fade-in-up">
          <span class="w-2.5 h-2.5 bg-[#D4A853] rounded-full animate-pulse"></span>
          <span class="text-[#B8923E] text-sm font-semibold tracking-wide uppercase font-['Space_Grotesk']">India's Premier Startup Ecosystem</span>
        </div>

        <!-- Main heading with gradient -->
        <h1 class="font-['Space_Grotesk'] text-5xl sm:text-6xl lg:text-7xl xl:text-[5.5rem] font-bold text-[#1A1A2E] leading-[1.02] tracking-tight animate-fade-in-up" style="animation-delay: 0.1s;">
          Meet Angel Investors for
          <span class="relative inline-block">
            <span class="bg-gradient-to-r from-[#D4A853] via-[#C9993D] to-[#B8923E] bg-clip-text text-transparent">Boundless</span>
            <span class="absolute -bottom-2 left-0 w-full h-[3px] bg-gradient-to-r from-[#D4A853]/50 via-[#D4A853] to-transparent rounded-full"></span>
          </span>
          <br/>Growth
        </h1>

        <!-- Subtitle with refined typography -->
        <p class="text-[#1A1A2E]/65 text-lg lg:text-xl leading-[1.75] max-w-xl animate-fade-in-up" style="animation-delay: 0.2s;">
          India's foremost platform dedicated to cultivating an extraordinary startup ecosystem. We are more than investors — we are architects of ambition, fostering a community where passionate founders transform dreams into reality.
        </p>

        <!-- CTA Buttons with premium styling -->
        <div class="flex flex-col sm:flex-row gap-5 pt-2 animate-fade-in-up" style="animation-delay: 0.3s;">
          <a
            href="/about"
            class="group relative inline-flex items-center justify-center gap-3 px-9 py-5 bg-gradient-to-r from-[#D4A853] to-[#B8923E] text-white font-semibold rounded-full overflow-hidden transition-all duration-500 hover:shadow-[0_0_50px_rgba(212,168,83,0.45)] hover:-translate-y-1"
          >
            <span class="relative z-10">Discover More</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="relative z-10 w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
            <div class="absolute inset-0 bg-gradient-to-r from-[#B8923E] to-[#D4A853] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          </a>
          <a
            href="/contact"
            class="group relative inline-flex items-center justify-center gap-3 px-9 py-5 border-2 border-[#1A1A2E]/15 text-[#1A1A2E] font-semibold rounded-full hover:bg-[#1A1A2E] hover:text-white hover:border-[#1A1A2E] transition-all duration-500"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <span>Talk With Us</span>
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="flex items-center gap-8 pt-4 animate-fade-in-up" style="animation-delay: 0.4s;">
          <div class="flex items-center gap-2">
            <div class="flex -space-x-2">
              <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[#D4A853] to-[#B8923E] border-2 border-white"></div>
              <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[#C9993D] to-[#D4A853] border-2 border-white"></div>
              <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[#B8923E] to-[#C9993D] border-2 border-white"></div>
            </div>
            <span class="text-sm text-[#1A1A2E]/50">100+ Investors</span>
          </div>
          <div class="w-px h-8 bg-[#D4A853]/20"></div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#D4A853]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <span class="text-sm text-[#1A1A2E]/50">Top Rated Platform</span>
          </div>
        </div>
      </div>

      <!-- Premium Visual Element - Central Emblem -->
      <div class="hidden lg:flex justify-center items-center relative">
        <div class="relative w-[520px] h-[520px]">
          <!-- Outer orbital rings with animation -->
          <div class="absolute inset-0 border border-[#D4A853]/15 rounded-full animate-spin-slow"></div>
          <div class="absolute inset-4 border border-[#D4A853]/10 rounded-full animate-spin-slow" style="animation-direction: reverse; animation-duration: 40s;"></div>
          <div class="absolute inset-8 border border-[#D4A853]/8 rounded-full animate-spin-slow" style="animation-duration: 50s;"></div>
          <div class="absolute inset-12 border border-[#D4A853]/5 rounded-full animate-spin-slow" style="animation-direction: reverse; animation-duration: 60s;"></div>

          <!-- Central emblem with glow -->
          <div class="absolute inset-16 bg-gradient-to-br from-[#D4A853] via-[#C9993D] to-[#B8923E] rounded-full flex items-center justify-center shadow-[0_0_80px_rgba(212,168,83,0.35)]">
            <div class="w-36 h-36 bg-white/10 rounded-full flex items-center justify-center backdrop-blur-sm border border-white/20">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-18 h-18 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
              </svg>
            </div>
          </div>

          <!-- Orbiting badge elements -->
          <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-2">
            <div class="w-16 h-16 bg-white/95 backdrop-blur-sm border border-[#D4A853]/30 rounded-full flex items-center justify-center shadow-[0_0_40px_rgba(212,168,83,0.2)] hover:scale-110 transition-transform duration-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[#D4A853]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
              </svg>
            </div>
          </div>

          <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-2">
            <div class="w-16 h-16 bg-white/95 backdrop-blur-sm border border-[#D4A853]/30 rounded-full flex items-center justify-center shadow-[0_0_40px_rgba(212,168,83,0.2)] hover:scale-110 transition-transform duration-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[#D4A853]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M6 3h12l4 6-10 13L2 9Z"/><path d="M11 3 8 9l4 13 4-13-3-6"/><path d="M2 9h20"/>
              </svg>
            </div>
          </div>

          <div class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-2">
            <div class="w-16 h-16 bg-white/95 backdrop-blur-sm border border-[#D4A853]/30 rounded-full flex items-center justify-center shadow-[0_0_40px_rgba(212,168,83,0.2)] hover:scale-110 transition-transform duration-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[#D4A853]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
          </div>

          <div class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-2">
            <div class="w-16 h-16 bg-white/95 backdrop-blur-sm border border-[#D4A853]/30 rounded-full flex items-center justify-center shadow-[0_0_40px_rgba(212,168,83,0.2)] hover:scale-110 transition-transform duration-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[#D4A853]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" x2="12" y1="2" y2="15"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 w-full h-40 bg-gradient-to-t from-[#F5F0E6] via-[#F5F0E6]/50 to-transparent"></div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.3; }
    50% { transform: translateY(-20px) rotate(5deg); opacity: 0.6; }
  }
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-float { animation: float 6s ease-in-out infinite; }
  .animate-fade-in-up { animation: fade-in-up 0.8s ease-out forwards; opacity: 0; }
  .animate-spin-slow { animation: spin-slow 30s linear infinite; }
</style>