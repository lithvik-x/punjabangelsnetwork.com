---
---

<section class="relative min-h-[90vh] flex items-center overflow-hidden bg-[#F5F0E6]">
  <!-- Subtle grid pattern -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(#D4A853 1px, transparent 1px), linear-gradient(90deg, #D4A853 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- Ambient warm glow -->
  <div class="absolute top-1/4 right-1/4 w-[700px] h-[700px] bg-[#D4A853]/10 rounded-full blur-[180px]"></div>

  <!-- Gold accent line top -->
  <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-[#D4A853]/40 to-transparent"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-24 lg:py-0">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Text Content -->
      <div class="space-y-8">
        <div class="inline-flex items-center gap-3 px-5 py-2.5 bg-[#D4A853]/10 border border-[#D4A853]/20 rounded-full">
          <span class="w-2 h-2 bg-[#D4A853] rounded-full animate-pulse"></span>
          <span class="text-[#B8923E] text-sm font-medium tracking-wide uppercase">India's Premier Startup Ecosystem</span>
        </div>

        <h1 class="font-['Space_Grotesk'] text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-bold text-[#1A1A2E] leading-[1.05] tracking-tight">
          Meet Angel Investors for
          <span class="bg-gradient-to-r from-[#D4A853] via-[#C9993D] to-[#B8923E] bg-clip-text text-transparent">Boundless</span>
          <br/>Growth
        </h1>

        <p class="text-[#1A1A2E]/70 text-lg lg:text-xl leading-relaxed max-w-xl">
          India's foremost platform dedicated to cultivating an extraordinary startup ecosystem. We are more than investors — we are architects of ambition, fostering a community where passionate founders transform dreams into reality.
        </p>

        <div class="flex flex-col sm:flex-row gap-5 pt-4">
          <a
            href="/about"
            class="group inline-flex items-center justify-center gap-3 px-8 py-4.5 bg-gradient-to-r from-[#D4A853] to-[#B8923E] text-white font-semibold rounded-full hover:shadow-[0_0_40px_rgba(212,168,83,0.4)] transition-all duration-300 hover:-translate-y-0.5"
          >
            Discover More
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
          <a
            href="/contact"
            class="group inline-flex items-center justify-center gap-3 px-8 py-4.5 border-2 border-[#1A1A2E]/20 text-[#1A1A2E] font-semibold rounded-full hover:bg-[#1A1A2E] hover:text-white transition-all duration-300"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Talk With Us
          </a>
        </div>
      </div>

      <!-- Visual Element - Professional emblem -->
      <div class="hidden lg:flex justify-center items-center relative">
        <div class="relative w-[480px] h-[480px]">
          <!-- Outer orbital ring -->
          <div class="absolute inset-0 border-2 border-[#D4A853]/20 rounded-full"></div>

          <!-- Middle orbital ring -->
          <div class="absolute inset-10 border border-[#D4A853]/15 rounded-full"></div>

          <!-- Inner orbital ring -->
          <div class="absolute inset-20 border border-[#D4A853]/10 rounded-full"></div>

          <!-- Central emblem -->
          <div class="absolute inset-8 bg-gradient-to-br from-[#D4A853] via-[#C9993D] to-[#B8923E] rounded-full flex items-center justify-center shadow-[0_0_60px_rgba(212,168,83,0.3)]">
            <div class="w-32 h-32 bg-white/10 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
              </svg>
            </div>
          </div>

          <!-- Orbiting elements -->
          <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1">
            <div class="w-14 h-14 bg-white border-2 border-[#D4A853] rounded-full flex items-center justify-center shadow-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-[#D4A853]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
              </svg>
            </div>
          </div>

          <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1">
            <div class="w-14 h-14 bg-white border-2 border-[#D4A853]/60 rounded-full flex items-center justify-center shadow-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-[#D4A853]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M6 3h12l4 6-10 13L2 9Z"/><path d="M11 3 8 9l4 13 4-13-3-6"/><path d="M2 9h20"/>
              </svg>
            </div>
          </div>

          <div class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-1">
            <div class="w-14 h-14 bg-white border-2 border-[#D4A853]/40 rounded-full flex items-center justify-center shadow-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-[#D4A853]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
          </div>

          <div class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1">
            <div class="w-14 h-14 bg-white border-2 border-[#D4A853]/40 rounded-full flex items-center justify-center shadow-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-[#D4A853]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" x2="12" y1="2" y2="15"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 w-full h-32 bg-gradient-to-t from-[#F5F0E6] to-transparent"></div>
</section>
