---
---

<section class="relative min-h-screen flex items-center overflow-hidden bg-[#FAF8F5]">
  <!-- Subtle texture overlay -->
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"></div>

  <!-- Elegant gold accent line -->
  <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#B8963E]/30 to-transparent"></div>

  <!-- Decorative corner elements -->
  <div class="absolute top-16 left-16 w-24 h-24 border-l-[1px] border-t-[1px] border-[#B8963E]/20"></div>
  <div class="absolute bottom-16 right-16 w-24 h-24 border-r-[1px] border-b-[1px] border-[#B8963E]/20"></div>

  <div class="relative max-w-[1600px] mx-auto px-8 lg:px-16 py-24">
    <div class="grid lg:grid-cols-2 gap-20 items-center min-h-[80vh]">
      <!-- Text Content - Editorial Layout -->
      <div class="space-y-10">
        <!-- Label -->
        <div class="animate-fade-in-up" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-3 text-[#B8963E] text-xs font-medium tracking-[0.25em] uppercase font-['Jost']">
            <span class="w-8 h-[1px] bg-[#B8963E]"></span>
            India's Premier Ecosystem
          </span>
        </div>

        <!-- Main Heading - Bodoni Moda -->
        <h1 class="animate-fade-in-up font-['Bodoni_Moda'] text-5xl sm:text-6xl lg:text-7xl xl:text-[4.5rem] font-medium text-[#1A1817] leading-[1.08] tracking-tight">
          Meet Angel<br/>
          Investors for
          <span class="relative inline-block">
            <span class="text-gold-gradient">Boundless</span>
            <!-- Elegant underline -->
            <svg class="absolute -bottom-2 left-0 w-full" viewBox="0 0 200 8" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M0 6C50 2 100 2 200 6" stroke="url(#heroGradient)" stroke-width="1.5"/>
              <defs>
                <linearGradient id="heroGradient" x1="0" y1="0" x2="200" y2="0">
                  <stop offset="0%" stop-color="#B8963E" stop-opacity="0"/>
                  <stop offset="50%" stop-color="#D4A853"/>
                  <stop offset="100%" stop-color="#B8963E" stop-opacity="0"/>
                </linearGradient>
              </defs>
            </svg>
          </span>
          <br/>Growth
        </h1>

        <!-- Subtitle - Jost -->
        <p class="animate-fade-in-up text-[#1A1817]/60 text-lg lg:text-xl leading-[1.8] max-w-lg font-['Jost'] font-light" style="animation-delay: 0.2s;">
          India's foremost platform dedicated to cultivating an extraordinary startup ecosystem. We are more than investors — we are architects of ambition.
        </p>

        <!-- CTA Buttons - Premium styling -->
        <div class="animate-fade-in-up flex flex-col sm:flex-row gap-5 pt-4" style="animation-delay: 0.3s;">
          <a
            href="/about"
            class="group relative inline-flex items-center justify-center gap-3 px-10 py-5 bg-[#1A1817] text-white font-['Jost'] font-medium tracking-wide rounded-full overflow-hidden transition-all duration-500 hover:shadow-luxe"
          >
            <span class="relative z-10">Discover More</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="relative z-10 w-5 h-5 transform group-hover:translate-x-1 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
            <!-- Shine effect on hover -->
            <div class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-700 bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
          </a>
          <a
            href="/contact"
            class="group relative inline-flex items-center justify-center gap-3 px-10 py-5 border border-[#1A1817]/20 text-[#1A1817] font-['Jost'] font-medium tracking-wide rounded-full overflow-hidden hover:border-[#1A1817]/40 hover:bg-[#1A1817]/5 transition-all duration-500"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
            </svg>
            <span>Talk With Us</span>
          </a>
        </div>

        <!-- Trust Indicators -->
        <div class="animate-fade-in-up flex items-center gap-10 pt-8" style="animation-delay: 0.4s;">
          <div class="flex items-center gap-3">
            <div class="flex -space-x-3">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-[#B8963E] to-[#D4A853] border-2 border-white flex items-center justify-center text-white text-xs font-medium">SM</div>
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-[#96751C] to-[#B8963E] border-2 border-white flex items-center justify-center text-white text-xs font-medium">AK</div>
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-[#D4A853] to-[#B8963E] border-2 border-white flex items-center justify-center text-white text-xs font-medium">RS</div>
            </div>
            <span class="text-[#1A1817]/50 text-sm font-['Jost']">100+ Investors</span>
          </div>
          <div class="w-[1px] h-10 bg-[#1A1817]/10"></div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#B8963E]" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <span class="text-[#1A1817]/50 text-sm font-['Jost']">Top Rated Platform</span>
          </div>
        </div>
      </div>

      <!-- Premium Visual Element - Abstract Emblem -->
      <div class="hidden lg:flex justify-center items-center relative animate-fade-in" style="animation-delay: 0.5s;">
        <div class="relative w-[500px] h-[500px]">
          <!-- Outer ethereal ring -->
          <div class="absolute inset-0 border border-[#B8963E]/10 rounded-full"></div>

          <!-- Middle ring with dash -->
          <div class="absolute inset-8 border border-[#B8963E]/15 rounded-full border-dashed"></div>

          <!-- Inner ring -->
          <div class="absolute inset-16 border border-[#B8963E]/20 rounded-full"></div>

          <!-- Central emblem -->
          <div class="absolute inset-24 bg-gradient-to-br from-[#B8963E] via-[#D4A853] to-[#96751C] rounded-full flex items-center justify-center shadow-[0_0_100px_rgba(184,150,62,0.3)]">
            <div class="w-28 h-28 bg-white/10 rounded-full flex items-center justify-center backdrop-blur-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-14 h-14 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
              </svg>
            </div>
          </div>

          <!-- Orbiting accent elements -->
          <div class="absolute top-4 left-1/2 -translate-x-1/2 w-16 h-16 bg-white rounded-full shadow-luxe-sm flex items-center justify-center animate-float">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[#B8963E]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0016.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 002 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
            </svg>
          </div>

          <div class="absolute bottom-4 left-1/2 -translate-x-1/2 w-16 h-16 bg-white rounded-full shadow-luxe-sm flex items-center justify-center animate-float" style="animation-delay: 1s;">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[#B8963E]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M6 3h12l4 6-10 13L2 9Z"/>
            </svg>
          </div>

          <div class="absolute left-4 top-1/2 -translate-y-1/2 w-16 h-16 bg-white rounded-full shadow-luxe-sm flex items-center justify-center animate-float" style="animation-delay: 2s;">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[#B8963E]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/>
            </svg>
          </div>

          <div class="absolute right-4 top-1/2 -translate-y-1/2 w-16 h-16 bg-white rounded-full shadow-luxe-sm flex items-center justify-center animate-float" style="animation-delay: 3s;">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[#B8963E]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/>
            </svg>
          </div>

          <!-- Gold accent dots -->
          <div class="absolute top-20 right-20 w-2 h-2 bg-[#B8963E]/40 rounded-full"></div>
          <div class="absolute bottom-32 left-16 w-3 h-3 bg-[#B8963E]/30 rounded-full"></div>
          <div class="absolute top-1/3 right-12 w-1.5 h-1.5 bg-[#B8963E]/50 rounded-full"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom fade with gradient -->
  <div class="absolute bottom-0 left-0 w-full h-40 bg-gradient-to-t from-[#FAF8F5] to-transparent"></div>
</section>