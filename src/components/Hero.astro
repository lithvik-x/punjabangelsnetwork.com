---
---

<section class="relative min-h-[90vh] flex items-center overflow-hidden bg-gradient-to-br from-[#1A1A2E] via-[#2D2D4A] to-[#1A1A2E]">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=\"60\" height=\"60\" viewBox=\"0 0 60 60\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cg fill=\"none\" fill-rule=\"evenodd\"%3E%3Cg fill=\"%23D4A853\" fill-opacity=\"0.4\"%3E%3Cpath d=\"M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
  </div>

  <!-- Floating Elements -->
  <div class="absolute top-1/4 left-10 w-64 h-64 bg-[#D4A853]/10 rounded-full blur-3xl animate-float"></div>
  <div class="absolute bottom-1/4 right-10 w-80 h-80 bg-[#D4A853]/10 rounded-full blur-3xl animate-float" style="animation-delay: -3s;"></div>

  <!-- Gold Accent Lines -->
  <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-[#D4A853] to-transparent"></div>

  <div class="relative max-w-7xl mx-auto px-4 py-20 lg:py-0">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Text Content -->
      <div class="text-center lg:text-left">
        <p class="text-[#D4A853] font-mono text-sm tracking-widest mb-4 animate-fade-in-up opacity-0" style="animation-delay: 0ms;">
          WELCOME TO PUNJAB ANGELS NETWORK
        </p>
        <h1 class="font-['DM_Serif_Display'] text-4xl sm:text-5xl lg:text-6xl xl:text-7xl text-white leading-tight mb-6 animate-fade-in-up opacity-0" style="animation-delay: 150ms;">
          Meet Angel Investors for
          <span class="text-gold-gradient">Boundless</span> Growth
        </h1>
        <p class="text-white/80 text-lg mb-8 max-w-xl mx-auto lg:mx-0 animate-fade-in-up opacity-0" style="animation-delay: 300ms;">
          India's foremost platform dedicated to cultivating a startup ecosystem. We are more than just an investment network — we are architects of ambition.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start animate-fade-in-up opacity-0" style="animation-delay: 450ms;">
          <a
            href="/about"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#D4A853] text-[#1A1A2E] font-semibold rounded-full hover:bg-[#B8923E] transition-all duration-300 hover:shadow-lg hover:shadow-[#D4A853]/30"
          >
            Discover More
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-white/30 text-white font-semibold rounded-full hover:bg-white/10 transition-all duration-300"
          >
            Talk With Us
          </a>
        </div>
      </div>

      <!-- Visual Element -->
      <div class="hidden lg:flex justify-center items-center relative">
        <div class="relative w-96 h-96">
          <!-- Outer ring -->
          <div class="absolute inset-0 border-2 border-[#D4A853]/30 rounded-full animate-pulse-gold"></div>
          <!-- Middle ring -->
          <div class="absolute inset-8 border-2 border-[#D4A853]/20 rounded-full"></div>
          <!-- Inner circle with icon -->
          <div class="absolute inset-16 bg-gradient-to-br from-[#D4A853] to-[#B8923E] rounded-full flex items-center justify-center shadow-2xl shadow-[#D4A853]/20">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-24 h-24 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
          </div>
          <!-- Orbiting dots -->
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-4 h-4 bg-[#D4A853] rounded-full shadow-lg shadow-[#D4A853]/50" style="animation: float 3s ease-in-out infinite;"></div>
          <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-4 h-4 bg-white/50 rounded-full" style="animation: float 3s ease-in-out infinite; animation-delay: -1.5s;"></div>
          <div class="absolute left-0 top-1/2 -translate-y-1/2 w-4 h-4 bg-white/30 rounded-full" style="animation: float 3s ease-in-out infinite; animation-delay: -0.75s;"></div>
          <div class="absolute right-0 top-1/2 -translate-y-1/2 w-4 h-4 bg-[#D4A853]/50 rounded-full" style="animation: float 3s ease-in-out infinite; animation-delay: -2.25s;"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom gradient fade -->
  <div class="absolute bottom-0 left-0 w-full h-32 bg-gradient-to-t from-[#FDFBF7] to-transparent"></div>
</section>
