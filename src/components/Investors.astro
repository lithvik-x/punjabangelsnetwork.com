---
const investors = [
  "Mr. Amit Madaan",
  "Saurav Munjal",
  "Mitesh Nandlaskar",
  "Ramanathan K",
  "Tushar Kapoor",
  "Rajesh Singla",
  "Amit Singal",
  "Suresh Jain",
  "Sundeep Gaba",
  "Vishal Gandhi",
  "Vishal Kedia",
  "Gaurav Sharma",
  "CA Apurv Bansal",
  "Nikhil Doda",
  "Vishal Sood",
  "Manoj Kumar",
  "Vivek Utreja",
  "Rajesh Azad",
  "Lehar Gandhi",
  "Nikhil Gupta",
  "Lalit Kumar Bansal",
  "Mr. Mandeep Singh",
  "Mandeep Sodhi",
  "Mr. Puneet Verma",
  "Ravjot Ahuluwalia",
  "Sunil Khullar",
  "Angad Bindra",
  "Sanjay Aggarwal",
  "Kiran kurwade",
  "Mr. Advait Upadhaya",
  "Ms. Shilpi Jain",
  "Sumant Handa",
  "Anil Channa",
  "Gaurav Vashisht",
  "Nikhil garg",
  "CA Manoj Lamba"
];
---

<section class="py-24 lg:py-32 bg-[#0A0A0B] relative overflow-hidden">
  <!-- Subtle grid pattern -->
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(#D4A853 1px, transparent 1px), linear-gradient(90deg, #D4A853 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- Ambient glow -->
  <div class="absolute bottom-0 right-1/4 w-[800px] h-[800px] bg-[#D4A853]/4 rounded-full blur-[200px]"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end gap-6 mb-12 reveal">
      <div>
        <div class="inline-flex items-center gap-3 mb-4">
          <div class="w-12 h-[1px] bg-[#D4A853]"></div>
          <span class="text-[#D4A853] text-sm font-medium tracking-[0.3em] uppercase font-['Space_Grotesk']">Our Network</span>
        </div>
        <h2 class="font-['Space_Grotesk'] text-4xl lg:text-5xl xl:text-6xl font-bold text-white">
          Our Network of
          <span class="bg-gradient-to-r from-[#D4A853] via-[#E8C47C] to-[#D4A853] bg-clip-text text-transparent"> Visionary Investors</span>
        </h2>
      </div>
      <a
        href="/our-team"
        class="group inline-flex items-center gap-2 px-6 py-3 border border-[#D4A853]/40 text-[#D4A853] font-semibold rounded-full hover:bg-[#D4A853] hover:text-[#0A0A0B] hover:border-[#D4A853] transition-all duration-300"
      >
        See All Investors
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>

    <div class="carousel-container flex gap-5 overflow-x-auto pb-4 -mx-4 px-4">
      {investors.map((investor) => (
        <div
          class="carousel-item flex-shrink-0 w-44 text-center"
        >
          <div class="w-full aspect-square bg-gradient-to-br from-[#1A1A1C] to-[#252528] rounded-2xl flex items-center justify-center mb-3 border border-white/5 hover:border-[#D4A853]/30 hover:scale-105 transition-all duration-300">
            <span class="font-['Space_Grotesk'] text-xl font-bold bg-gradient-to-r from-[#D4A853] to-[#E8C47C] bg-clip-text text-transparent">
              {investor.split(' ').map(n => n[0]).slice(0, 2).join('')}
            </span>
          </div>
          <p class="text-white/70 text-sm font-medium truncate px-1">{investor}</p>
        </div>
      ))}
    </div>
  </div>
</section>
