---

<section class="py-32 lg:py-48 bg-[#FAF8F5] relative overflow-hidden">
  <!-- Subtle texture -->
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(#B8963E 1px, transparent 1px), linear-gradient(90deg, #B8963E 1px, transparent 1px); background-size: 100px 100px;"></div>

  <!-- Ambient glows -->
  <div class="absolute bottom-0 right-1/4 w-[800px] h-[800px] bg-[#B8963E]/5 rounded-full blur-[200px]"></div>

  <div class="relative max-w-[1600px] mx-auto px-8 lg:px-16">
    <!-- Header with premium styling -->
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end gap-8 mb-14 reveal">
      <div>
        <div class="flex items-center gap-4 mb-6">
          <div class="w-12 h-[1px] bg-gradient-to-r from-[#B8963E] to-transparent"></div>
          <span class="text-[#B8963E] text-xs font-['Jost'] font-medium tracking-[0.3em] uppercase">Our Network</span>
        </div>
        <h2 class="font-['Bodoni_Moda'] text-4xl lg:text-5xl xl:text-6xl font-medium text-[#1A1817] leading-tight">
          Our Network of <span class="text-gold-gradient">Visionary Investors</span>
        </h2>
      </div>
      <a
        href="/our-team"
        class="group inline-flex items-center gap-3 px-7 py-3.5 border border-[#B8963E] text-[#B8963E] font-['Jost'] font-medium rounded-full hover:bg-[#B8963E] hover:text-white hover:shadow-luxe-sm transition-all duration-500"
      >
        See All Investors
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Premium carousel -->
    <div class="carousel-container flex gap-6 overflow-x-auto pb-6 -mx-4 px-4 scrollbar-hide">
      {investors.map((investor) => (
        <div class="carousel-item flex-shrink-0">
          <div class="w-48 h-48 bg-white/90 backdrop-blur-xl rounded-3xl flex flex-col items-center justify-center mb-4 border border-[#1A1817]/5 hover:border-[#B8963E]/30 hover:shadow-luxe-sm hover:-translate-y-2 transition-all duration-500 group relative overflow-hidden">
            <!-- Gradient background on hover -->
            <div class="absolute inset-0 bg-gradient-to-br from-[#B8963E]/10 via-transparent to-[#96751C]/10 rounded-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

            <div class="relative w-full h-full flex items-center justify-center bg-gradient-to-br from-[#B8963E]/8 to-transparent rounded-3xl">
              <span class="font-['Bodoni_Moda'] text-2xl font-medium bg-gradient-to-r from-[#B8963E] to-[#96751C] bg-clip-text text-transparent">
                {investor.split(' ').map(n => n[0]).slice(0, 2).join('')}
              </span>
            </div>
          </div>
          <p class="text-[#1A1817]/60 text-sm font-['Jost'] font-light text-center px-2 truncate">{investor}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>