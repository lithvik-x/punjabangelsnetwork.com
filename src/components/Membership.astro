---
const investorBenefits = [
  "Gain exclusive entry to a network of promising startups and investment opportunities",
  "Enjoy exclusive access to comprehensive due diligence reports and market insights",
  "Access curated investment deals exclusively available to you",
  "Receive priority consideration for investment deals",
  "Attend invitations-only pitch events and exclusive networking sessions for investors",
  "Benefit from end-to-end support for startup investments",
  "Participate in investor masterclasses and workshops for continuous learning",
  "Explore opportunities to join investment syndicates and co-investment deals",
  "Seize the opportunity to start investing from as low as 1 Lakh onward"
];

const corporateBenefits = [
  "Exclusive invites to curated networking events and pitch sessions",
  "Entry to a wealth of educational resources, online workshops, and webinars",
  "Connect with a network of promising startups and investors",
  "Attend masterclasses and in-person workshops for hands-on learning",
  "Avail discounted co-working space and infrastructure support through our workspace partners",
  "Tap into cost-effective professional services provided by our partner organization"
];
---

<section class="py-24 lg:py-32 bg-[#EBE4D6] relative overflow-hidden">
  <!-- Subtle grid pattern -->
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(#D4A853 1px, transparent 1px), linear-gradient(90deg, #D4A853 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- Ambient warm glow -->
  <div class="absolute bottom-0 right-0 w-[700px] h-[700px] bg-[#D4A853]/8 rounded-full blur-[200px]"></div>

  <div class="relative max-w-[1600px] mx-auto px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <div class="inline-flex items-center gap-3 mb-6">
        <div class="w-12 h-[2px] bg-[#D4A853]"></div>
        <span class="text-[#B8923E] text-sm font-medium tracking-[0.3em] uppercase font-['Space_Grotesk']">Membership</span>
        <div class="w-12 h-[2px] bg-[#D4A853]"></div>
      </div>
      <h2 class="font-['Space_Grotesk'] text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-bold text-[#1A1A2E] mb-4">
        Discover the power of membership with
        <span class="bg-gradient-to-r from-[#D4A853] via-[#C9993D] to-[#B8923E] bg-clip-text text-transparent"> India's largest revenue-based financing platform</span>
      </h2>
    </div>

    <!-- Tabs -->
    <div class="bg-white rounded-3xl shadow-lg border border-[#D4A853]/10 overflow-hidden reveal">
      <!-- Tab Headers -->
      <div class="flex border-b border-[#D4A853]/10">
        <button
          class="membership-tab flex-1 px-6 lg:px-8 py-5 lg:py-6 text-base lg:text-lg font-semibold text-[#B8923E] border-b-2 border-[#D4A853] transition-all duration-300"
          data-tab="investors"
        >
          Investors
        </button>
        <button
          class="membership-tab flex-1 px-6 lg:px-8 py-5 lg:py-6 text-base lg:text-lg font-semibold text-[#1A1A2E]/40 hover:text-[#B8923E] transition-all duration-300"
          data-tab="corporates"
        >
          Corporates
        </button>
      </div>

      <!-- Tab Content -->
      <div class="p-8 lg:p-12">
        <!-- Investors Tab -->
        <div id="investors-content" class="membership-content">
          <div class="grid lg:grid-cols-3 gap-8 lg:gap-12 items-start">
            <div class="lg:col-span-2">
              <h3 class="font-['Space_Grotesk'] text-2xl lg:text-3xl font-bold text-[#1A1A2E] mb-6">For Investors</h3>
              <ul class="space-y-4">
                {investorBenefits.map((benefit, index) => (
                  <li class="flex items-start gap-4" style={`animation-delay: ${index * 50}ms;`}>
                    <div class="w-6 h-6 bg-[#D4A853]/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#B8923E]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                    </div>
                    <span class="text-[#1A1A2E]/60">{benefit}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="lg:col-span-1">
              <div class="bg-gradient-to-br from-[#F5F0E6] to-[#EBE4D6] rounded-2xl p-6 lg:p-8 text-center border border-[#D4A853]/10">
                <h4 class="font-['Space_Grotesk'] text-xl lg:text-2xl font-bold text-[#1A1A2E] mb-3">Start Investing Today</h4>
                <p class="text-[#1A1A2E]/50 text-sm mb-6">Begin your journey as a Punjab Angels investor</p>
                <a
                  href="/investor-enrollment"
                  class="group inline-flex items-center justify-center gap-2 w-full px-5 py-4 bg-gradient-to-r from-[#D4A853] to-[#B8923E] text-white font-semibold rounded-full hover:shadow-[0_0_30px_rgba(212,168,83,0.3)] transition-all duration-300"
                >
                  <span>Begin Your Investment Journey</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Corporates Tab -->
        <div id="corporates-content" class="membership-content hidden">
          <div class="grid lg:grid-cols-3 gap-8 lg:gap-12 items-start">
            <div class="lg:col-span-2">
              <h3 class="font-['Space_Grotesk'] text-2xl lg:text-3xl font-bold text-[#1A1A2E] mb-6">For Corporates</h3>
              <ul class="space-y-4">
                {corporateBenefits.map((benefit, index) => (
                  <li class="flex items-start gap-4" style={`animation-delay: ${index * 50}ms;`}>
                    <div class="w-6 h-6 bg-[#D4A853]/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#B8923E]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                    </div>
                    <span class="text-[#1A1A2E]/60">{benefit}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="lg:col-span-1">
              <div class="bg-gradient-to-br from-[#F5F0E6] to-[#EBE4D6] rounded-2xl p-6 lg:p-8 text-center border border-[#D4A853]/10">
                <h4 class="font-['Space_Grotesk'] text-xl lg:text-2xl font-bold text-[#1A1A2E] mb-3">Join Our Corporate Network</h4>
                <p class="text-[#1A1A2E]/50 text-sm mb-6">Get started with corporate membership</p>
                <a
                  href="/corporate-membership-enrollment"
                  class="group inline-flex items-center justify-center gap-2 w-full px-5 py-4 bg-gradient-to-r from-[#D4A853] to-[#B8923E] text-white font-semibold rounded-full hover:shadow-[0_0_30px_rgba(212,168,83,0.3)] transition-all duration-300"
                >
                  <span>Get Started</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll('.membership-tab');
  const contents = document.querySelectorAll('.membership-content');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-tab');

      tabs.forEach(t => {
        t.classList.remove('text-[#B8923E]', 'border-b-2', 'border-[#D4A853]');
        t.classList.add('text-[#1A1A2E]/40');
      });

      tab.classList.add('text-[#B8923E]', 'border-b-2', 'border-[#D4A853]');
      tab.classList.remove('text-[#1A1A2E]/40');

      contents.forEach(content => {
        content.classList.add('hidden');
      });

      document.getElementById(`${target}-content`)?.classList.remove('hidden');
    });
  });
</script>
