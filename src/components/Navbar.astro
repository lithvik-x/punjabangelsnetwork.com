---
const navLinks = [
  { name: "Home", href: "/" },
  { name: "About", href: "/about" },
  { name: "Fund Raising", href: "/fund-raising" },
  { name: "Startup", href: "/startup" },
  { name: "Investor", href: "/investors" },
  { name: "Institutional Support", href: "/institutional-support" },
  { name: "Events", href: "/events" },
  { name: "Contact", href: "/contact" },
];
---

<nav class="navbar-main fixed top-0 left-0 right-0 z-50 transition-all duration-500" id="main-navbar">
  <div class="mx-auto px-6 lg:px-12">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-4 group">
        <div class="w-12 h-12 bg-gradient-to-br from-[#B8963E] to-[#96751C] rounded-xl flex items-center justify-center shadow-[0_0_30px_rgba(184,150,62,0.25)] group-hover:shadow-[0_0_40px_rgba(184,150,62,0.35)] transition-all duration-300">
          <span class="text-white font-['Bodoni_Moda'] font-medium text-xl">PA</span>
        </div>
        <div class="hidden sm:block">
          <span class="font-['Bodoni_Moda'] text-xl font-medium text-[#1A1817] tracking-wide">Punjab Angels</span>
          <span class="block text-[10px] text-[#1A1817]/40 tracking-[0.2em] uppercase font-['Jost']">Network</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-2">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="px-4 py-2 text-sm font-['Jost'] font-light text-[#1A1817]/60 hover:text-[#B8963E] transition-colors duration-300 rounded-lg hover:bg-[#B8963E]/5 nav-link"
          >
            {link.name}
          </a>
        ))}
      </div>

      <!-- CTA + Mobile Toggle -->
      <div class="flex items-center gap-4">
        <a
          href="/apply"
          class="hidden sm:inline-flex items-center gap-2 px-7 py-3 bg-[#1A1817] text-white font-['Jost'] font-medium text-sm tracking-wide rounded-full hover:shadow-luxe transition-all duration-500 hover:-translate-y-0.5 group"
        >
          <span>Apply Now</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:translate-x-0.5 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>

        <!-- Mobile menu button -->
        <button class="lg:hidden w-11 h-11 flex items-center justify-center rounded-xl hover:bg-[#1A1817]/5 transition-colors duration-300" id="mobile-menu-btn">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#1A1817]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="lg:hidden hidden bg-white/95 backdrop-blur-xl border-t border-[#1A1817]/5 mx-4 rounded-2xl mt-2" id="mobile-menu">
    <div class="px-6 py-6 space-y-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="block px-4 py-3 text-[#1A1817]/70 hover:text-[#B8963E] hover:bg-[#B8963E]/5 rounded-xl transition-all duration-300 font-['Jost']"
        >
          {link.name}
        </a>
      ))}
      <a
        href="/apply"
        class="block mt-4 mx-2 px-6 py-3.5 bg-[#1A1817] text-white font-['Jost'] font-medium rounded-full text-center"
      >
        Apply Now
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>