---
const navLinks = [
  { name: "Home", href: "/" },
  { name: "About", href: "/about" },
  { name: "Fund Raising", href: "/fund-raising" },
  { name: "Startup", href: "/startup" },
  { name: "Investor", href: "/investors" },
  { name: "Institutional Support", href: "/institutional-support" },
  { name: "Events", href: "/events" },
  { name: "Contact", href: "/contact" },
];
---

<nav class="navbar-main fixed top-0 left-0 right-0 z-50 transition-all duration-500" id="main-navbar">
  <!-- TopBar spacer -->
  <div class="h-10"></div>

  <div class="mx-auto px-4 lg:px-6">
    <div class="flex items-center justify-between h-20 bg-[#F5F0E6]/80 backdrop-blur-2xl border border-[#D4A853]/10 rounded-2xl shadow-[0_0_40px_rgba(212,168,83,0.08)] transition-all duration-500" id="navbar-inner">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 ml-2 group">
        <div class="w-12 h-12 bg-gradient-to-br from-[#D4A853] to-[#B8923E] rounded-xl flex items-center justify-center shadow-[0_0_25px_rgba(212,168,83,0.35)] group-hover:shadow-[0_0_35px_rgba(212,168,83,0.5)] transition-all duration-300">
          <span class="text-white font-bold text-xl font-['Space_Grotesk']">PA</span>
        </div>
        <div class="hidden sm:block group-hover:opacity-80 transition-opacity duration-300">
          <span class="font-['Space_Grotesk'] text-xl font-bold text-[#1A1A2E]">Punjab Angels</span>
          <span class="block text-xs text-[#1A1A2E]/40 tracking-wider uppercase">Network</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="px-4 py-2.5 text-sm font-medium text-[#1A1A2E]/60 hover:text-[#D4A853] transition-all duration-300 rounded-xl hover:bg-[#D4A853]/5 nav-link"
          >
            {link.name}
          </a>
        ))}
      </div>

      <!-- CTA + Mobile Toggle -->
      <div class="flex items-center gap-4 mr-2">
        <a
          href="/apply"
          class="hidden sm:inline-flex items-center gap-2.5 px-7 py-3 bg-gradient-to-r from-[#D4A853] to-[#B8923E] text-white font-semibold rounded-full hover:shadow-[0_0_40px_rgba(212,168,83,0.5)] transition-all duration-500 hover:-translate-y-0.5 group"
        >
          <span>Apply Now</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>

        <!-- Mobile menu button -->
        <button class="lg:hidden w-11 h-11 flex items-center justify-center rounded-xl hover:bg-[#D4A853]/10 transition-colors duration-300" id="mobile-menu-btn">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#1A1A2E]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="lg:hidden hidden bg-[#F5F0E6]/95 backdrop-blur-2xl border-x border-b border-[#D4A853]/10 rounded-b-2xl mx-4" id="mobile-menu">
    <div class="px-4 py-5 space-y-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="block px-4 py-3 text-[#1A1A2E]/70 hover:text-[#D4A853] hover:bg-[#D4A853]/5 rounded-xl transition-all duration-300"
        >
          {link.name}
        </a>
      ))}
      <a
        href="/apply"
        class="block mt-4 mx-2 px-6 py-3.5 bg-gradient-to-r from-[#D4A853] to-[#B8923E] text-white font-semibold rounded-full text-center"
      >
        Apply Now
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  // Navbar scroll effect
  const navbar = document.getElementById('main-navbar');
  const navbarInner = document.getElementById('navbar-inner');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbarInner?.classList.add('shadow-[0_0_60px_rgba(212,168,83,0.15)]');
      navbarInner?.classList.remove('rounded-2xl');
      navbarInner?.classList.add('rounded-full');
    } else {
      navbarInner?.classList.remove('shadow-[0_0_60px_rgba(212,168,83,0.15)]');
      navbarInner?.classList.remove('rounded-full');
      navbarInner?.classList.add('rounded-2xl');
    }
  });
</script>