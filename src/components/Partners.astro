---
const partners = [
  { name: "Hem Angels", url: "" },
  { name: "Sydney Investors", url: "" },
  { name: "Indian Healthcare Angels", url: "" },
  { name: "Static flow", url: "" }
];
---

<section class="py-28 lg:py-40 bg-[#EBE4D6] relative overflow-hidden">
  <!-- Sophisticated grid pattern -->
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(#D4A853 1px, transparent 1px), linear-gradient(90deg, #D4A853 1px, transparent 1px); background-size: 80px 80px;"></div>

  <!-- Ambient glows -->
  <div class="absolute top-0 right-0 w-[700px] h-[700px] bg-[#D4A853]/6 rounded-full blur-[200px]"></div>
  <div class="absolute bottom-0 left-1/4 w-[500px] h-[500px] bg-[#B8923E]/5 rounded-full blur-[150px]"></div>

  <div class="relative max-w-[1600px] mx-auto px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-20 reveal">
      <div class="inline-flex items-center gap-4 mb-8">
        <div class="w-14 h-[2px] bg-gradient-to-r from-transparent to-[#D4A853]"></div>
        <span class="text-[#B8923E] text-sm font-semibold tracking-[0.35em] uppercase font-['Space_Grotesk']">Collaborations</span>
        <div class="w-14 h-[2px] bg-gradient-to-l from-transparent to-[#D4A853]"></div>
      </div>
      <h2 class="font-['Space_Grotesk'] text-4xl lg:text-5xl xl:text-6xl font-bold text-[#1A1A2E] mb-6">
        Meet Our
        <span class="bg-gradient-to-r from-[#D4A853] via-[#C9993D] to-[#B8923E] bg-clip-text text-transparent"> Dynamic Partners</span>
      </h2>
      <p class="text-[#1A1A2E]/50 mt-4 text-lg">Connect, Collaborate, Conquer</p>
    </div>

    <!-- Partners grid with premium cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-7 lg:gap-10">
      {partners.map((partner, index) => (
        <a
          href={partner.url || "#"}
          class="group flex flex-col items-center justify-center p-8 lg:p-10 bg-white/90 backdrop-blur-xl rounded-[2rem] border border-[#D4A853]/10 hover:border-[#D4A853]/40 transition-all duration-500 reveal hover:shadow-[0_0_50px_rgba(212,168,83,0.15)] hover:-translate-y-3 overflow-hidden relative"
          style={`animation-delay: ${index * 100}ms;`}
        >
          <!-- Inner gradient glow on hover -->
          <div class="absolute inset-0 bg-gradient-to-br from-[#D4A853]/10 via-transparent to-[#B8923E]/10 rounded-[2rem] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <!-- Decorative element -->
          <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-[#D4A853]/10 to-transparent rounded-full -translate-y-12 translate-x-12 group-hover:from-[#D4A853]/20 transition-all duration-500"></div>

          <!-- Logo container -->
          <div class="relative w-24 h-24 bg-gradient-to-br from-[#F5F0E6] to-[#EBE4D6] rounded-3xl flex items-center justify-center mb-6 border border-[#D4A853]/15 group-hover:border-[#D4A853]/30 group-hover:scale-105 transition-all duration-500">
            <span class="font-['Space_Grotesk'] text-xl font-bold bg-gradient-to-r from-[#D4A853] to-[#B8923E] bg-clip-text text-transparent text-center px-3">
              {partner.name.split(' ').map(n => n[0]).join('')}
            </span>
          </div>

          <!-- Name -->
          <span class="relative font-semibold text-[#1A1A2E]/60 group-hover:text-[#B8923E] transition-colors duration-300 text-center">
            {partner.name}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>