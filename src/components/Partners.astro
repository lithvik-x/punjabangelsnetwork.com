---
const partners = [
  { name: "Hem Angels", url: "" },
  { name: "Sydney Investors", url: "" },
  { name: "Indian Healthcare Angels", url: "" },
  { name: "Static flow", url: "" }
];
---

<section class="py-32 lg:py-48 bg-[#E8E4DF] relative overflow-hidden">
  <!-- Subtle texture -->
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(#B8963E 1px, transparent 1px), linear-gradient(90deg, #B8963E 1px, transparent 1px); background-size: 100px 100px;"></div>

  <!-- Ambient glows -->
  <div class="absolute top-0 right-0 w-[700px] h-[700px] bg-[#B8963E]/5 rounded-full blur-[200px]"></div>

  <div class="relative max-w-[1600px] mx-auto px-8 lg:px-16">
    <!-- Section header - Centered editorial -->
    <div class="text-center mb-20 reveal">
      <div class="flex items-center justify-center gap-4 mb-8">
        <div class="w-16 h-[1px] bg-gradient-to-r from-transparent to-[#B8963E]"></div>
        <span class="text-[#B8963E] text-xs font-['Jost'] font-medium tracking-[0.3em] uppercase">Collaborations</span>
        <div class="w-16 h-[1px] bg-gradient-to-l from-transparent to-[#B8963E]"></div>
      </div>
      <h2 class="font-['Bodoni_Moda'] text-4xl lg:text-5xl xl:text-6xl font-medium text-[#1A1817] mb-6">
        Meet Our <span class="text-gold-gradient">Dynamic Partners</span>
      </h2>
      <p class="text-[#1A1817]/50 mt-4 text-lg font-['Jost'] font-light">Connect, Collaborate, Conquer</p>
    </div>

    <!-- Partners grid with premium cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-7 lg:gap-10">
      {partners.map((partner, index) => (
        <a
          href={partner.url || "#"}
          class="group flex flex-col items-center justify-center p-8 lg:p-10 bg-white/90 backdrop-blur-xl rounded-3xl border border-[#1A1817]/5 hover:border-[#B8963E]/30 transition-all duration-500 reveal hover:shadow-luxe hover:-translate-y-3 overflow-hidden relative"
          style={`animation-delay: ${index * 100}ms;`}
        >
          <!-- Inner gradient glow on hover -->
          <div class="absolute inset-0 bg-gradient-to-br from-[#B8963E]/10 via-transparent to-[#96751C]/10 rounded-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <!-- Decorative element -->
          <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-[#B8963E]/10 to-transparent rounded-full -translate-y-12 translate-x-12 group-hover:from-[#B8963E]/20 transition-all duration-500"></div>

          <!-- Logo container -->
          <div class="relative w-24 h-24 bg-gradient-to-br from-[#FAF8F5] to-[#E8E4DF] rounded-3xl flex items-center justify-center mb-6 border border-[#B8963E]/15 group-hover:border-[#B8963E]/30 group-hover:scale-105 transition-all duration-500">
            <span class="font-['Bodoni_Moda'] text-xl font-medium bg-gradient-to-r from-[#B8963E] to-[#96751C] bg-clip-text text-transparent text-center px-3">
              {partner.name.split(' ').map(n => n[0]).join('')}
            </span>
          </div>

          <!-- Name -->
          <span class="relative font-['Jost'] font-medium text-[#1A1817]/60 group-hover:text-[#B8963E] transition-colors duration-300 text-center">
            {partner.name}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>