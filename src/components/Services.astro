---

<section class="py-32 lg:py-48 bg-[#E8E4DF] relative overflow-hidden">
  <!-- Subtle texture -->
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(#B8963E 1px, transparent 1px), linear-gradient(90deg, #B8963E 1px, transparent 1px); background-size: 100px 100px;"></div>

  <div class="relative max-w-[1600px] mx-auto px-8 lg:px-16">
    <!-- Section header - Centered editorial -->
    <div class="text-center mb-20 reveal">
      <div class="flex items-center justify-center gap-4 mb-8">
        <div class="w-16 h-[1px] bg-gradient-to-r from-transparent to-[#B8963E]"></div>
        <span class="text-[#B8963E] text-xs font-['Jost'] font-medium tracking-[0.3em] uppercase">Our Services</span>
        <div class="w-16 h-[1px] bg-gradient-to-l from-transparent to-[#B8963E]"></div>
      </div>
      <h2 class="font-['Bodoni_Moda'] text-4xl lg:text-5xl xl:text-6xl font-medium text-[#1A1817] mb-6">
        Services We <span class="text-gold-gradient">Offer</span>
      </h2>
    </div>

    <!-- Services - Magazine style grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.map((service, index) => (
        <div
          class="group relative bg-white/90 backdrop-blur-xl rounded-3xl p-10 border border-[#1A1817]/5 hover:border-[#B8963E]/30 transition-all duration-500 reveal hover:shadow-luxe overflow-hidden"
          style={`animation-delay: ${index * 100}ms;`}
        >
          <!-- Subtle gradient overlay on hover -->
          <div class="absolute inset-0 bg-gradient-to-br from-[#B8963E]/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-3xl"></div>

          <!-- Icon -->
          <div class="relative w-14 h-14 bg-[#FAF8F5] rounded-2xl flex items-center justify-center mb-8 group-hover:bg-[#B8963E]/10 transition-all duration-500 group-hover:scale-110">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-[#B8963E]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d={service.icon}/>
            </svg>
          </div>

          <!-- Content -->
          <h3 class="relative font-['Bodoni_Moda'] text-2xl font-medium text-[#1A1817] mb-4 group-hover:text-[#B8963E] transition-colors duration-300">{service.title}</h3>
          <p class="relative text-[#1A1817]/50 leading-relaxed font-['Jost'] font-light">{service.description}</p>

          <!-- Bottom accent line -->
          <div class="absolute bottom-0 left-10 right-10 h-[1px] bg-gradient-to-r from-transparent via-[#B8963E]/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </div>
      ))}
    </div>
  </div>
</section>