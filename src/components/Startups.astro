---
const startups = [
  { name: "Let's Game Now", url: "https://letsgamenow.com/home" },
  { name: "Basil", url: "https://www.basil.health/" },
  { name: "Taupe", url: "https://mytaupe.com/" },
  { name: "SmileKey", url: "https://smilekey.in/" },
  { name: "eSoulify", url: "https://esoullyf.in/" },
  { name: "Whizz EV", url: "#" }
];
---

<section class="py-28 lg:py-40 bg-[#F5F0E6] relative overflow-hidden">
  <!-- Sophisticated grid pattern -->
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(#D4A853 1px, transparent 1px), linear-gradient(90deg, #D4A853 1px, transparent 1px); background-size: 80px 80px;"></div>

  <!-- Ambient glows -->
  <div class="absolute top-0 left-1/4 w-[700px] h-[700px] bg-[#D4A853]/6 rounded-full blur-[200px]"></div>
  <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-[#B8923E]/5 rounded-full blur-[150px]"></div>

  <div class="relative max-w-[1600px] mx-auto px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-20 reveal">
      <div class="inline-flex items-center gap-4 mb-8">
        <div class="w-14 h-[2px] bg-gradient-to-r from-transparent to-[#D4A853]"></div>
        <span class="text-[#B8923E] text-sm font-semibold tracking-[0.35em] uppercase font-['Space_Grotesk']">Portfolio</span>
        <div class="w-14 h-[2px] bg-gradient-to-l from-transparent to-[#D4A853]"></div>
      </div>
      <h2 class="font-['Space_Grotesk'] text-4xl lg:text-5xl xl:text-6xl font-bold text-[#1A1A2E] mb-6">
        <span class="bg-gradient-to-r from-[#D4A853] via-[#C9993D] to-[#B8923E] bg-clip-text text-transparent">STARTUPS</span> PORTFOLIO
      </h2>
      <p class="text-[#1A1A2E]/50 mt-4 text-lg">Let's support us to help them</p>
    </div>

    <!-- Premium carousel -->
    <div class="carousel-container flex gap-7 overflow-x-auto pb-6 -mx-4 px-4 scrollbar-hide">
      {startups.map((startup, index) => (
        <a
          href={startup.url}
          target="_blank"
          rel="noopener noreferrer"
          class="carousel-item flex-shrink-0 group"
        >
          <div class="w-72 h-48 bg-white/90 backdrop-blur-xl rounded-3xl flex items-center justify-center mb-5 border border-[#D4A853]/10 group-hover:border-[#D4A853]/40 group-hover:shadow-[0_0_50px_rgba(212,168,83,0.15)] group-hover:-translate-y-2 transition-all duration-500 overflow-hidden relative">
            <!-- Inner gradient on hover -->
            <div class="absolute inset-0 bg-gradient-to-br from-[#D4A853]/10 via-transparent to-[#B8923E]/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

            <!-- Decorative corner -->
            <div class="absolute top-0 right-0 w-16 h-16 bg-gradient-to-bl from-[#D4A853]/10 to-transparent rounded-full -translate-y-8 translate-x-8 group-hover:from-[#D4A853]/20 transition-all duration-500"></div>

            <div class="relative w-full h-full bg-gradient-to-br from-[#D4A853]/8 to-transparent flex items-center justify-center px-6">
              <span class="font-['Space_Grotesk'] text-lg lg:text-xl font-bold bg-gradient-to-r from-[#D4A853] to-[#B8923E] bg-clip-text text-transparent text-center group-hover:scale-105 transition-transform duration-500">
                {startup.name}
              </span>
            </div>
          </div>
          <p class="text-[#1A1A2E]/60 font-medium text-center group-hover:text-[#B8923E] transition-colors duration-300">
            {startup.name}
          </p>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>