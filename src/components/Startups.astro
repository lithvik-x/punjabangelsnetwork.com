---
const startups = [
  { name: "Let's Game Now", url: "https://letsgamenow.com/home" },
  { name: "Basil", url: "https://www.basil.health/" },
  { name: "Taupe", url: "https://mytaupe.com/" },
  { name: "SmileKey", url: "https://smilekey.in/" },
  { name: "eSoulify", url: "https://esoullyf.in/" },
  { name: "Whizz EV", url: "#" }
];
---

<section class="py-24 lg:py-32 bg-[#111113] relative overflow-hidden">
  <!-- Subtle grid pattern -->
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(#D4A853 1px, transparent 1px), linear-gradient(90deg, #D4A853 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- Ambient glow -->
  <div class="absolute top-0 left-1/4 w-[700px] h-[700px] bg-[#D4A853]/4 rounded-full blur-[200px]"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <div class="inline-flex items-center gap-3 mb-6">
        <div class="w-12 h-[1px] bg-[#D4A853]"></div>
        <span class="text-[#D4A853] text-sm font-medium tracking-[0.3em] uppercase font-['Space_Grotesk']">Portfolio</span>
        <div class="w-12 h-[1px] bg-[#D4A853]"></div>
      </div>
      <h2 class="font-['Space_Grotesk'] text-4xl lg:text-5xl xl:text-6xl font-bold text-white mb-4">
        <span class="bg-gradient-to-r from-[#D4A853] via-[#E8C47C] to-[#D4A853] bg-clip-text text-transparent">STARTUPS</span> PORTFOLIO
      </h2>
      <p class="text-white/50 mt-4">Let's support us to help them</p>
    </div>

    <div class="carousel-container flex gap-6 overflow-x-auto pb-4 -mx-4 px-4">
      {startups.map((startup) => (
        <a
          href={startup.url}
          target="_blank"
          rel="noopener noreferrer"
          class="carousel-item flex-shrink-0 w-64 group"
        >
          <div class="w-full aspect-video bg-gradient-to-br from-[#1A1A1C] to-[#252528] rounded-2xl flex items-center justify-center mb-3 border border-white/5 group-hover:border-[#D4A853]/30 group-hover:scale-105 transition-all duration-300 overflow-hidden">
            <div class="w-full h-full bg-gradient-to-br from-[#D4A853]/10 to-transparent flex items-center justify-center px-4">
              <span class="font-['Space_Grotesk'] text-base lg:text-lg font-semibold text-[#D4A853] text-center">
                {startup.name}
              </span>
            </div>
          </div>
          <p class="text-white/70 font-medium text-center group-hover:text-[#D4A853] transition-colors duration-300">
            {startup.name}
          </p>
        </a>
      ))}
    </div>
  </div>
</section>
