---
const startups = [
  { name: "Let's Game Now", url: "https://letsgamenow.com/home" },
  { name: "Basil", url: "https://www.basil.health/" },
  { name: "Taupe", url: "https://mytaupe.com/" },
  { name: "SmileKey", url: "https://smilekey.in/" },
  { name: "eSoulify", url: "https://esoullyf.in/" },
  { name: "Whizz EV", url: "#" }
];
---

<section class="py-32 lg:py-48 bg-[#FAF8F5] relative overflow-hidden">
  <!-- Subtle texture -->
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(#B8963E 1px, transparent 1px), linear-gradient(90deg, #B8963E 1px, transparent 1px); background-size: 100px 100px;"></div>

  <!-- Ambient glows -->
  <div class="absolute top-0 left-1/4 w-[700px] h-[700px] bg-[#B8963E]/5 rounded-full blur-[200px]"></div>

  <div class="relative max-w-[1600px] mx-auto px-8 lg:px-16">
    <!-- Section header - Centered editorial -->
    <div class="text-center mb-20 reveal">
      <div class="flex items-center justify-center gap-4 mb-8">
        <div class="w-16 h-[1px] bg-gradient-to-r from-transparent to-[#B8963E]"></div>
        <span class="text-[#B8963E] text-xs font-['Jost'] font-medium tracking-[0.3em] uppercase">Portfolio</span>
        <div class="w-16 h-[1px] bg-gradient-to-l from-transparent to-[#B8963E]"></div>
      </div>
      <h2 class="font-['Bodoni_Moda'] text-4xl lg:text-5xl xl:text-6xl font-medium text-[#1A1817] mb-6">
        <span class="text-gold-gradient">STARTUPS</span> PORTFOLIO
      </h2>
      <p class="text-[#1A1817]/50 mt-4 text-lg font-['Jost'] font-light">Let's support us to help them</p>
    </div>

    <!-- Premium carousel -->
    <div class="carousel-container flex gap-7 overflow-x-auto pb-6 -mx-4 px-4 scrollbar-hide">
      {startups.map((startup, index) => (
        <a
          href={startup.url}
          target="_blank"
          rel="noopener noreferrer"
          class="carousel-item flex-shrink-0 group"
        >
          <div class="w-72 h-48 bg-white/90 backdrop-blur-xl rounded-3xl flex items-center justify-center mb-5 border border-[#1A1817]/5 group-hover:border-[#B8963E]/30 group-hover:shadow-luxe group-hover:-translate-y-2 transition-all duration-500 overflow-hidden relative">
            <!-- Inner gradient on hover -->
            <div class="absolute inset-0 bg-gradient-to-br from-[#B8963E]/10 via-transparent to-[#96751C]/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

            <!-- Decorative corner -->
            <div class="absolute top-0 right-0 w-16 h-16 bg-gradient-to-bl from-[#B8963E]/10 to-transparent rounded-full -translate-y-8 translate-x-8 group-hover:from-[#B8963E]/20 transition-all duration-500"></div>

            <div class="relative w-full h-full bg-gradient-to-br from-[#B8963E]/8 to-transparent flex items-center justify-center px-6">
              <span class="font-['Bodoni_Moda'] text-lg lg:text-xl font-medium bg-gradient-to-r from-[#B8963E] to-[#96751C] bg-clip-text text-transparent text-center group-hover:scale-105 transition-transform duration-500">
                {startup.name}
              </span>
            </div>
          </div>
          <p class="text-[#1A1817]/60 font-['Jost'] font-light text-center group-hover:text-[#B8963E] transition-colors duration-300">
            {startup.name}
          </p>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>