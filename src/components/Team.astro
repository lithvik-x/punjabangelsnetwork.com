---
---

<section class="py-28 lg:py-40 bg-[#F5F0E6] relative overflow-hidden">
  <!-- Sophisticated grid pattern -->
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(#D4A853 1px, transparent 1px), linear-gradient(90deg, #D4A853 1px, transparent 1px); background-size: 80px 80px;"></div>

  <!-- Ambient glows -->
  <div class="absolute top-1/3 right-0 w-[700px] h-[700px] bg-[#D4A853]/6 rounded-full blur-[200px]"></div>
  <div class="absolute bottom-0 left-1/4 w-[500px] h-[500px] bg-[#B8923E]/5 rounded-full blur-[150px]"></div>

  <div class="relative max-w-[1600px] mx-auto px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-20 reveal">
      <div class="inline-flex items-center gap-4 mb-8">
        <div class="w-14 h-[2px] bg-gradient-to-r from-transparent to-[#D4A853]"></div>
        <span class="text-[#B8923E] text-sm font-semibold tracking-[0.35em] uppercase font-['Space_Grotesk']">Leadership</span>
        <div class="w-14 h-[2px] bg-gradient-to-l from-transparent to-[#D4A853]"></div>
      </div>
      <h2 class="font-['Space_Grotesk'] text-4xl lg:text-5xl xl:text-6xl font-bold text-[#1A1A2E]">
        Meet Our
        <span class="bg-gradient-to-r from-[#D4A853] via-[#C9993D] to-[#B8923E] bg-clip-text text-transparent"> Chairman</span>
      </h2>
    </div>

    <!-- Premium Chairman Card -->
    <div class="max-w-5xl mx-auto">
      <div class="relative bg-white/90 backdrop-blur-xl rounded-[2rem] p-10 lg:p-14 shadow-[0_0_80px_rgba(212,168,83,0.12)] border border-[#D4A853]/10 reveal overflow-hidden">
        <!-- Inner glow effect -->
        <div class="absolute inset-0 bg-gradient-to-br from-[#D4A853]/5 via-transparent to-[#B8923E]/5 rounded-[2rem]"></div>

        <!-- Decorative corner elements -->
        <div class="absolute top-0 right-0 w-40 h-40 bg-gradient-to-bl from-[#D4A853]/10 to-transparent rounded-full translate-x-20 -translate-y-20"></div>
        <div class="absolute bottom-0 left-0 w-60 h-60 bg-gradient-to-tr from-[#B8923E]/8 to-transparent rounded-full -translate-x-30 translate-y-30"></div>

        <div class="relative grid md:grid-cols-3 gap-10 lg:gap-16 items-start">
          <!-- Avatar with premium styling -->
          <div class="flex flex-col items-center">
            <div class="relative">
              <div class="w-36 h-36 lg:w-44 lg:h-44 bg-gradient-to-br from-[#D4A853] via-[#C9993D] to-[#B8923E] rounded-3xl flex items-center justify-center shadow-[0_0_60px_rgba(212,168,83,0.35)]">
                <span class="font-['Space_Grotesk'] text-4xl lg:text-5xl font-bold text-white">SM</span>
              </div>
              <!-- Badge -->
              <div class="absolute -bottom-2 -right-2 w-12 h-12 bg-white rounded-xl shadow-lg flex items-center justify-center border border-[#D4A853]/20">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#D4A853]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              </div>
            </div>
            <h3 class="font-['Space_Grotesk'] text-2xl lg:text-3xl font-bold text-[#1A1A2E] text-center mt-6">Sahil Makkar</h3>
            <p class="text-[#B8923E] font-semibold text-center mt-2 tracking-wide">Chairman & CEO</p>
          </div>

          <!-- Content -->
          <div class="md:col-span-2">
            <h4 class="font-['Space_Grotesk'] text-2xl lg:text-3xl xl:text-4xl font-bold text-[#1A1A2E] mb-6 leading-tight">
              Visionary Leader Driving Start-Up Success!
            </h4>
            <p class="text-[#1A1A2E]/65 leading-relaxed mb-5 text-lg">
              Chairman & CEO of Punjab Angels Network, Fellow Chartered Accountant, An Alumnus of Indian School of Business (ISB) and has done Executive Education Programme from Indian Institute of Management (IIM) – Bangalore.
            </p>
            <p class="text-[#1A1A2E]/50 leading-relaxed mb-8">
              Sahil Makkar is a Nationally recognized Exponential Thought Leader, Strategic Business/Startup & Scale-up Advisor, He has years of experience in assisting Start-up's/ Corporates clients in raising capital both equity and debt, mergers and acquisitions, Scaling up Businesses.
            </p>

            <!-- CTA -->
            <a
              href="/our-team#chairman"
              class="group inline-flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-[#D4A853] to-[#B8923E] text-white font-semibold rounded-full hover:shadow-[0_0_40px_rgba(212,168,83,0.4)] transition-all duration-500 hover:-translate-y-0.5"
            >
              <span>Read More</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>