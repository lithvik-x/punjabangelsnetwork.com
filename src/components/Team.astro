---
---

<section class="py-24 lg:py-32 bg-[#F5F0E6] relative overflow-hidden">
  <!-- Subtle grid pattern -->
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(#D4A853 1px, transparent 1px), linear-gradient(90deg, #D4A853 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- Ambient warm glow -->
  <div class="absolute top-1/3 right-0 w-[700px] h-[700px] bg-[#D4A853]/8 rounded-full blur-[180px]"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <div class="inline-flex items-center gap-3 mb-6">
        <div class="w-12 h-[2px] bg-[#D4A853]"></div>
        <span class="text-[#B8923E] text-sm font-medium tracking-[0.3em] uppercase font-['Space_Grotesk']">Leadership</span>
        <div class="w-12 h-[2px] bg-[#D4A853]"></div>
      </div>
      <h2 class="font-['Space_Grotesk'] text-4xl lg:text-5xl xl:text-6xl font-bold text-[#1A1A2E] mb-4">
        Meet Our
        <span class="bg-gradient-to-r from-[#D4A853] via-[#C9993D] to-[#B8923E] bg-clip-text text-transparent"> Chairman</span>
      </h2>
    </div>

    <div class="max-w-4xl mx-auto">
      <div class="bg-white rounded-3xl p-8 lg:p-12 shadow-lg border border-[#D4A853]/10 reveal">
        <div class="grid md:grid-cols-3 gap-8 lg:gap-12 items-start">
          <!-- Avatar -->
          <div class="flex flex-col items-center">
            <div class="w-32 h-32 lg:w-40 lg:h-40 bg-gradient-to-br from-[#D4A853] to-[#B8923E] rounded-2xl flex items-center justify-center shadow-lg mb-4">
              <span class="font-['Space_Grotesk'] text-4xl lg:text-5xl font-bold text-white">SM</span>
            </div>
            <h3 class="font-['Space_Grotesk'] text-2xl font-bold text-[#1A1A2E] text-center">Sahil Makkar</h3>
            <p class="text-[#B8923E] font-medium text-center mt-1">Chairman & CEO</p>
          </div>

          <!-- Content -->
          <div class="md:col-span-2">
            <h4 class="font-['Space_Grotesk'] text-2xl lg:text-3xl font-bold text-[#1A1A2E] mb-4">Visionary Leader Driving Start-Up Success!</h4>
            <p class="text-[#1A1A2E]/70 leading-relaxed mb-6">
              Chairman & CEO of Punjab Angels Network, Fellow Chartered Accountant, An Alumnus of Indian School of Business (ISB) and has done Executive Education Programme from Indian Institute of Management (IIM) – Bangalore.
            </p>
            <p class="text-[#1A1A2E]/50 leading-relaxed mb-6">
              Sahil Makkar is a Nationally recognized Exponential Thought Leader, Strategic Business/Startup & Scale-up Advisor, He has years of experience in assisting Start-up's/ Corporates clients in raising capital both equity and debt, mergers and acquisitions, Scaling up Businesses.
            </p>
            <a
              href="/our-team#chairman"
              class="group inline-flex items-center gap-2 text-[#B8923E] font-semibold hover:text-[#D4A853] transition-colors duration-300"
            >
              <span>Read More</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
