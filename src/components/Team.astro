    <div class="max-w-4xl mx-auto">
      <div class="bg-gradient-to-br from-[#1A1A2E] to-[#2D2D4A] rounded-3xl p-8 lg:p-12 reveal">
        <div class="grid md:grid-cols-3 gap-8 items-start">
          <!-- Avatar -->
          <div class="flex flex-col items-center">
            <div class="w-40 h-40 bg-gradient-to-br from-[#D4A853] to-[#B8923E] rounded-2xl flex items-center justify-center shadow-xl mb-4">
