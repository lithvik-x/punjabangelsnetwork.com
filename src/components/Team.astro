---
---

<section class="py-32 lg:py-48 bg-[#FAF8F5] relative overflow-hidden">
  <!-- Subtle texture -->
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(#B8963E 1px, transparent 1px), linear-gradient(90deg, #B8963E 1px, transparent 1px); background-size: 100px 100px;"></div>

  <!-- Ambient glows -->
  <div class="absolute top-1/3 right-0 w-[700px] h-[700px] bg-[#B8963E]/5 rounded-full blur-[200px]"></div>

  <div class="relative max-w-[1600px] mx-auto px-8 lg:px-16">
    <!-- Section header - Centered editorial -->
    <div class="text-center mb-20 reveal">
      <div class="flex items-center justify-center gap-4 mb-8">
        <div class="w-16 h-[1px] bg-gradient-to-r from-transparent to-[#B8963E]"></div>
        <span class="text-[#B8963E] text-xs font-['Jost'] font-medium tracking-[0.3em] uppercase">Leadership</span>
        <div class="w-16 h-[1px] bg-gradient-to-l from-transparent to-[#B8963E]"></div>
      </div>
      <h2 class="font-['Bodoni_Moda'] text-4xl lg:text-5xl xl:text-6xl font-medium text-[#1A1817]">
        Meet Our <span class="text-gold-gradient">Chairman</span>
      </h2>
    </div>

    <!-- Premium Chairman Card -->
    <div class="max-w-5xl mx-auto">
      <div class="relative bg-white/90 backdrop-blur-xl rounded-3xl p-10 lg:p-14 shadow-luxe border border-[#1A1817]/5 reveal overflow-hidden">
        <!-- Inner gradient glow -->
        <div class="absolute inset-0 bg-gradient-to-br from-[#B8963E]/5 via-transparent to-[#96751C]/5 rounded-3xl"></div>

        <!-- Decorative corner -->
        <div class="absolute top-0 right-0 w-40 h-40 bg-gradient-to-bl from-[#B8963E]/10 to-transparent rounded-full translate-x-20 -translate-y-20"></div>

        <div class="relative grid md:grid-cols-3 gap-10 lg:gap-16 items-start">
          <!-- Avatar with premium styling -->
          <div class="flex flex-col items-center">
            <div class="relative">
              <div class="w-36 h-36 lg:w-44 lg:h-44 bg-gradient-to-br from-[#B8963E] via-[#D4A853] to-[#96751C] rounded-full flex items-center justify-center shadow-[0_0_60px_rgba(184,150,62,0.3)]">
                <span class="font-['Bodoni_Moda'] text-4xl lg:text-5xl font-medium text-white">SM</span>
              </div>
              <!-- Badge -->
              <div class="absolute -bottom-2 -right-2 w-12 h-12 bg-white rounded-xl shadow-luxe-sm flex items-center justify-center border border-[#B8963E]/20">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#B8963E]" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              </div>
            </div>
            <h3 class="font-['Bodoni_Moda'] text-2xl lg:text-3xl font-medium text-[#1A1817] text-center mt-6">Sahil Makkar</h3>
            <p class="text-[#B8963E] font-['Jost'] font-medium text-center mt-2 tracking-wide">Chairman & CEO</p>
          </div>

          <!-- Content -->
          <div class="md:col-span-2">
            <h4 class="font-['Bodoni_Moda'] text-2xl lg:text-3xl xl:text-4xl font-medium text-[#1A1817] mb-6 leading-tight">
              Visionary Leader Driving Start-Up Success!
            </h4>
            <p class="text-[#1A1817]/65 leading-relaxed mb-5 text-lg font-['Jost'] font-light">
              Chairman & CEO of Punjab Angels Network, Fellow Chartered Accountant, An Alumnus of Indian School of Business (ISB) and has done Executive Education Programme from Indian Institute of Management (IIM) – Bangalore.
            </p>
            <p class="text-[#1A1817]/50 leading-relaxed mb-8 font-['Jost']">
              Sahil Makkar is a Nationally recognized Exponential Thought Leader, Strategic Business/Startup & Scale-up Advisor, He has years of experience in assisting Start-up's/ Corporates clients in raising capital both equity and debt, mergers and acquisitions, Scaling up Businesses.
            </p>

            <!-- CTA -->
            <a
              href="/our-team#chairman"
              class="group inline-flex items-center gap-3 px-8 py-4 bg-[#1A1817] text-white font-['Jost'] font-medium rounded-full hover:shadow-luxe transition-all duration-500 hover:-translate-y-0.5"
            >
              <span>Read More</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>