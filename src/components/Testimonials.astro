---
const testimonials = [
  {
    quote: "Being an investor with Punjab Angels has been a strategic and fulfilling choice. The platform not only aligns with my vision for innovative investments but also fosters a sense of community where proactive collaboration thrives. Proud to contribute to the vibrant genre of success they cultivate.",
    name: "Manish",
    role: "Investor"
  }
];
---

<section class="py-24 lg:py-32 bg-[#0A0A0B] relative overflow-hidden">
  <!-- Subtle grid pattern -->
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(#D4A853 1px, transparent 1px), linear-gradient(90deg, #D4A853 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- Ambient glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#D4A853]/3 rounded-full blur-[180px]"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <div class="inline-flex items-center gap-3 mb-6">
        <div class="w-12 h-[1px] bg-[#D4A853]"></div>
        <span class="text-[#D4A853] text-sm font-medium tracking-[0.3em] uppercase font-['Space_Grotesk']">Testimonials</span>
        <div class="w-12 h-[1px] bg-[#D4A853]"></div>
      </div>
      <h2 class="font-['Space_Grotesk'] text-4xl lg:text-5xl xl:text-6xl font-bold text-white mb-4">
        Stories that Speak
        <span class="bg-gradient-to-r from-[#D4A853] via-[#E8C47C] to-[#D4A853] bg-clip-text text-transparent"> Real Success</span>
      </h2>
      <p class="text-white/50 mt-4">Voices of Victory</p>
    </div>

    <div class="max-w-3xl mx-auto reveal">
      <div class="bg-[#1A1A1C] rounded-3xl p-8 lg:p-12 border border-white/5">
        <div class="flex flex-col items-center text-center">
          <!-- Quote Icon -->
          <div class="w-16 h-16 bg-[#D4A853]/10 rounded-full flex items-center justify-center mb-8">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[#D4A853]" viewBox="0 0 24 24" fill="currentColor">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>
          </div>

          <blockquote class="text-lg lg:text-xl xl:text-2xl text-white/80 leading-relaxed mb-10 font-['Space_Grotesk'] italic">
            "{testimonials[0].quote}"
          </blockquote>

          <div class="flex items-center gap-4">
            <div class="w-14 h-14 bg-gradient-to-br from-[#D4A853] to-[#B8923E] rounded-full flex items-center justify-center shadow-[0_0_30px_rgba(212,168,83,0.3)]">
              <span class="font-['Space_Grotesk'] text-xl font-bold text-white">
                {testimonials[0].name[0]}
              </span>
            </div>
            <div class="text-left">
              <p class="font-semibold text-white">{testimonials[0].name}</p>
              <p class="text-[#D4A853] text-sm">{testimonials[0].role}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
