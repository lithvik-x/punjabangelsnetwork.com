---
const testimonials = [
  {
    quote: "Being an investor with Punjab Angels has been a strategic and fulfilling choice. The platform not only aligns with my vision for innovative investments but also fosters a sense of community where proactive collaboration thrives. Proud to contribute to the vibrant genre of success they cultivate.",
    name: "Manish",
    role: "Investor"
  }
];
---

<section class="py-20 lg:py-32 bg-[#F5F0E6]">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-16 reveal">
      <p class="text-[#D4A853] font-mono text-sm tracking-widest mb-4">TESTIMONIALS</p>
      <h2 class="font-['DM_Serif_Display'] text-4xl lg:text-5xl text-[#1A1A2E]">
        Stories that Speak <span class="text-gold-gradient">Real Success Stories</span>
      </h2>
      <p class="text-[#6B6B6B] mt-4">Voices of Victory</p>
    </div>

    <div class="max-w-3xl mx-auto">
      <div class="bg-white rounded-3xl p-8 lg:p-12 shadow-xl reveal">
        <div class="flex flex-col items-center text-center">
          <!-- Quote Icon -->
          <div class="w-16 h-16 bg-[#D4A853]/10 rounded-full flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[#D4A853]" viewBox="0 0 24 24" fill="currentColor">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>
          </div>

          <blockquote class="text-xl lg:text-2xl text-[#2D2D2D] leading-relaxed mb-8 font-['DM_Serif_Display'] italic">
            "{testimonials[0].quote}"
          </blockquote>

          <div class="flex items-center gap-4">
            <div class="w-14 h-14 bg-gradient-to-br from-[#D4A853] to-[#B8923E] rounded-full flex items-center justify-center">
              <span class="font-['DM_Serif_Display'] text-xl text-white">
                {testimonials[0].name[0]}
              </span>
            </div>
            <div class="text-left">
              <p class="font-semibold text-[#1A1A2E]">{testimonials[0].name}</p>
              <p class="text-[#6B6B6B] text-sm">{testimonials[0].role}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
