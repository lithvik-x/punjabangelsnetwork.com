---
const testimonials = [
  {
    quote: "Our startup journey was significantly smoothened by Punjab Angels. Beyond just securing crucial funds, the platform played an important role in connecting us with key players and industry influencers. Their amazing support is a true explanation of their commitment to our success.",
    name: "Rishav",
    role: "S.Manager"
  }
];
---

<section class="py-32 lg:py-48 bg-[#E8E4DF] relative overflow-hidden">
  <!-- Subtle texture -->
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(#B8963E 1px, transparent 1px), linear-gradient(90deg, #B8963E 1px, transparent 1px); background-size: 100px 100px;"></div>

  <!-- Ambient glows -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] bg-[#B8963E]/5 rounded-full blur-[200px]"></div>

  <div class="relative max-w-[1600px] mx-auto px-8 lg:px-16">
    <!-- Section header - Centered editorial -->
    <div class="text-center mb-20 reveal">
      <div class="flex items-center justify-center gap-4 mb-8">
        <div class="w-16 h-[1px] bg-gradient-to-r from-transparent to-[#B8963E]"></div>
        <span class="text-[#B8963E] text-xs font-['Jost'] font-medium tracking-[0.3em] uppercase">Testimonials</span>
        <div class="w-16 h-[1px] bg-gradient-to-l from-transparent to-[#B8963E]"></div>
      </div>
      <h2 class="font-['Bodoni_Moda'] text-4xl lg:text-5xl xl:text-6xl font-medium text-[#1A1817] mb-6">
        Stories that Speak <span class="text-gold-gradient">Real Success</span>
      </h2>
      <p class="text-[#1A1817]/50 mt-4 text-lg font-['Jost'] font-light">Voices of Victory</p>
    </div>

    <!-- Premium testimonial card -->
    <div class="max-w-4xl mx-auto reveal">
      <div class="relative bg-white/90 backdrop-blur-xl rounded-3xl p-12 lg:p-16 shadow-luxe border border-[#1A1817]/5 overflow-hidden">
        <!-- Inner gradient glow -->
        <div class="absolute inset-0 bg-gradient-to-br from-[#B8963E]/5 via-transparent to-[#96751C]/5 rounded-3xl"></div>

        <!-- Decorative elements -->
        <div class="absolute top-0 right-0 w-40 h-40 bg-gradient-to-bl from-[#B8963E]/10 to-transparent rounded-full -translate-y-20 translate-x-20"></div>
        <div class="absolute bottom-0 left-0 w-60 h-60 bg-gradient-to-tr from-[#96751C]/8 to-transparent rounded-full translate-y-30 -translate-x-30"></div>

        <!-- Quote icon -->
        <div class="relative w-20 h-20 bg-gradient-to-br from-[#B8963E]/15 to-[#B8963E]/5 rounded-2xl flex items-center justify-center mx-auto mb-10">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-[#B8963E]" viewBox="0 0 24 24" fill="currentColor">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>
        </div>

        <!-- Quote text -->
        <blockquote class="relative text-xl lg:text-2xl xl:text-3xl text-[#1A1817]/75 leading-[1.7] mb-12 font-['Jost'] font-light italic text-center">
          "{testimonials[0].quote}"
        </blockquote>

        <!-- Author -->
        <div class="relative flex items-center justify-center gap-5">
          <div class="w-16 h-16 bg-gradient-to-br from-[#B8963E] to-[#96751C] rounded-2xl flex items-center justify-center shadow-luxe-sm">
            <span class="font-['Bodoni_Moda'] text-2xl font-medium text-white">
              {testimonials[0].name[0]}
            </span>
          </div>
          <div class="text-left">
            <p class="font-['Jost'] font-medium text-[#1A1817] text-lg">{testimonials[0].name}</p>
            <p class="text-[#B8963E] font-['Jost'] font-medium">{testimonials[0].role}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>