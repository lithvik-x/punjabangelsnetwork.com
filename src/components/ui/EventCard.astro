---
interface Props {
  title: string;
  date: string;
  location: string;
  category?: string;
  href: string;
  image?: string;
}

const { title, date, location, category, href, image } = Astro.props;
---

<a href={href} class="group block bg-white rounded-2xl overflow-hidden border border-[#1A1817]/5 hover:border-[#B8963E]/20 transition-all duration-500 hover:shadow-luxe hover:-translate-y-1">
  <!-- Image -->
  <div class="relative h-48 bg-gradient-to-br from-[#B8963E]/10 to-[#96751C]/10 overflow-hidden">
    {image ? (
      <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
    ) : (
      <div class="absolute inset-0 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-[#B8963E]/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
        </svg>
      </div>
    )}
    <!-- Category badge -->
    {category && (
      <span class="absolute top-4 left-4 px-3 py-1 bg-[#1A1817]/80 backdrop-blur-sm text-white text-xs font-medium tracking-wide rounded-full font-['Jost']">
        {category}
      </span>
    )}
  </div>

  <!-- Content -->
  <div class="p-6">
    <h3 class="font-['Bodoni_Moda'] text-xl font-medium text-[#1A1817] group-hover:text-[#B8963E] transition-colors duration-300 leading-tight">
      {title}
    </h3>

    <div class="mt-4 flex items-center gap-4 text-sm text-[#1A1817]/50 font-['Jost']">
      <span class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
        </svg>
        {date}
      </span>
      <span class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
        </svg>
        {location}
      </span>
    </div>

    <!-- Arrow indicator -->
    <div class="mt-4 flex items-center gap-2 text-[#B8963E] text-sm font-medium font-['Jost']">
      <span>View Details</span>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
      </svg>
    </div>
  </div>
</a>
