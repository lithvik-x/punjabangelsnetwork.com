---
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  description?: string;
  align?: 'left' | 'center';
  light?: boolean;
}

const { label, title, subtitle, description, align = 'center', light = false } = Astro.props;
---

<div class:list={[
  "section-header mb-16",
  align === 'center' && 'text-center'
]}>
  {label && (
    <div class:list={[
      "flex items-center gap-4 mb-6",
      align === 'center' && 'justify-center'
    ]}>
      <div class:list={[
        "w-12 h-[1px] bg-gradient-to-r",
        light ? "from-white/40 to-transparent" : "from-[#B8963E] to-transparent"
      ]}></div>
      <span class:list={[
        "text-xs font-medium tracking-[0.3em] uppercase font-['Jost']",
        light ? "text-white/60" : "text-[#B8963E]"
      ]}>
        {label}
      </span>
    </div>
  )}

  <h2 class:list={[
    "font-['Bodoni_Moda'] font-medium tracking-tight leading-[1.1]",
    "text-4xl sm:text-5xl lg:text-6xl xl:text-7xl",
    light ? "text-white" : "text-[#1A1817]"
  ]}>
    {title}
  </h2>

  {subtitle && (
    <p class:list={[
      "mt-4 text-lg lg:text-xl font-['Jost'] font-light",
      light ? "text-white/70" : "text-[#1A1817]/60"
    ]}>
      {subtitle}
    </p>
  )}

  {description && (
    <p class:list={[
      "mt-6 text-base lg:text-lg leading-[1.8] max-w-2xl mx-auto",
      light ? "text-white/60" : "text-[#1A1817]/50",
      align === 'left' && "ml-0"
    ]}>
      {description}
    </p>
  )}
</div>
