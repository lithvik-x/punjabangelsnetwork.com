---
interface Props {
  number: string;
  label: string;
  icon?: string;
}

const { number, label, icon } = Astro.props;
---

<div class="group relative bg-white rounded-2xl p-6 lg:p-8 border border-[#1A1817]/5 hover:border-[#B8963E]/20 transition-all duration-500 hover:shadow-luxe-sm text-center overflow-hidden">
  <!-- Subtle inner gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#B8963E]/3 via-transparent to-[#96751C]/3 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

  <div class="relative">
    <span class="font-['Bodoni_Moda'] text-5xl lg:text-6xl font-medium text-gold-gradient group-hover:scale-105 transition-transform duration-500 inline-block">
      {number}
    </span>
    <p class="text-[#1A1817]/40 mt-3 text-sm font-['Jost'] font-light tracking-wide">
      {label}
    </p>
  </div>
</div>
