---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Blog">
  <TopBar />
  <Navbar />
  <main>
    <!-- Blog Hero -->
    <section class="relative py-32 lg:py-48 bg-[#FAF8F5] overflow-hidden">
      <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(#B8963E 1px, transparent 1px), linear-gradient(90deg, #B8963E 1px, transparent 1px); background-size: 100px 100px;"></div>

      <div class="relative max-w-[1600px] mx-auto px-8 lg:px-16 text-center">
        <div class="flex items-center justify-center gap-4 mb-6">
          <div class="w-12 h-[1px] bg-gradient-to-r from-transparent to-[#B8963E]"></div>
          <span class="text-[#B8963E] text-xs font-medium tracking-[0.3em] uppercase font-['Jost']">Insights</span>
          <div class="w-12 h-[1px] bg-gradient-to-l from-transparent to-[#B8963E]"></div>
        </div>
        <h1 class="font-['Bodoni_Moda'] text-5xl sm:text-6xl lg:text-7xl font-medium text-[#1A1817] leading-[1.1] tracking-tight">
          <span class="text-gold-gradient">Blog</span>
        </h1>
        <p class="mt-6 text-lg lg:text-xl text-[#1A1817]/60 max-w-2xl mx-auto font-['Jost']">
          Insights, stories, and knowledge from the Punjab Angels Network ecosystem.
        </p>
      </div>
    </section>

    <!-- Blog Content -->
    <section class="py-24 lg:py-32 bg-white">
      <div class="max-w-[1600px] mx-auto px-8 lg:px-16">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Blog Card 1 -->
          <article class="group bg-[#FAF8F5] rounded-3xl overflow-hidden border border-[#1A1817]/5 hover:border-[#B8963E]/20 transition-all duration-500">
            <div class="relative h-52 bg-gradient-to-br from-[#B8963E]/10 to-[#96751C]/10 overflow-hidden">
              <div class="absolute inset-0 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-[#B8963E]/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
              </div>
            </div>
            <div class="p-8">
              <div class="flex items-center gap-4 text-xs text-[#1A1817]/40 font-['Jost'] mb-4">
                <span>December 15, 2025</span>
                <span>•</span>
                <span>5 min read</span>
              </div>
              <h2 class="font-['Bodoni_Moda'] text-xl font-medium text-[#1A1817] mb-3 group-hover:text-[#B8963E] transition-colors duration-300">
                The Future of Startup Ecosystem in Punjab
              </h2>
              <p class="text-[#1A1817]/60 font-['Jost'] text-sm leading-relaxed mb-6">
                Exploring the emerging trends and opportunities in Punjab's startup landscape and what it means for entrepreneurs.
              </p>
              <a href="#" class="inline-flex items-center gap-2 text-[#B8963E] font-['Jost'] text-sm font-medium">
                <span>Read More</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </article>

          <!-- Blog Card 2 -->
          <article class="group bg-[#FAF8F5] rounded-3xl overflow-hidden border border-[#1A1817]/5 hover:border-[#B8963E]/20 transition-all duration-500">
            <div class="relative h-52 bg-gradient-to-br from-[#B8963E]/10 to-[#96751C]/10 overflow-hidden">
              <div class="absolute inset-0 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-[#B8963E]/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
            </div>
            <div class="p-8">
              <div class="flex items-center gap-4 text-xs text-[#1A1817]/40 font-['Jost'] mb-4">
                <span>November 28, 2025</span>
                <span>•</span>
                <span>7 min read</span>
              </div>
              <h2 class="font-['Bodoni_Moda'] text-xl font-medium text-[#1A1817] mb-3 group-hover:text-[#B8963E] transition-colors duration-300">
                How to Pitch to Angel Investors
              </h2>
              <p class="text-[#1A1817]/60 font-['Jost'] text-sm leading-relaxed mb-6">
                A comprehensive guide on crafting the perfect pitch deck and presentation for angel investors.
              </p>
              <a href="#" class="inline-flex items-center gap-2 text-[#B8963E] font-['Jost'] text-sm font-medium">
                <span>Read More</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </article>

          <!-- Blog Card 3 -->
          <article class="group bg-[#FAF8F5] rounded-3xl overflow-hidden border border-[#1A1817]/5 hover:border-[#B8963E]/20 transition-all duration-500">
            <div class="relative h-52 bg-gradient-to-br from-[#B8963E]/10 to-[#96751C]/10 overflow-hidden">
              <div class="absolute inset-0 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-[#B8963E]/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
                </svg>
              </div>
            </div>
            <div class="p-8">
              <div class="flex items-center gap-4 text-xs text-[#1A1817]/40 font-['Jost'] mb-4">
                <span>October 15, 2025</span>
                <span>•</span>
                <span>6 min read</span>
              </div>
              <h2 class="font-['Bodoni_Moda'] text-xl font-medium text-[#1A1817] mb-3 group-hover:text-[#B8963E] transition-colors duration-300">
                Building Strong Founder Networks
              </h2>
              <p class="text-[#1A1817]/60 font-['Jost'] text-sm leading-relaxed mb-6">
                Why networking matters for startup founders and how to build meaningful connections.
              </p>
              <a href="#" class="inline-flex items-center gap-2 text-[#B8963E] font-['Jost'] text-sm font-medium">
                <span>Read More</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </article>
        </div>

        <!-- Newsletter -->
        <div class="mt-20 bg-[#1A1817] rounded-3xl p-8 lg:p-16 text-center">
          <h3 class="font-['Bodoni_Moda'] text-3xl lg:text-4xl font-medium text-white mb-4">Stay Updated</h3>
          <p class="text-white/60 font-['Jost'] mb-8 max-w-xl mx-auto">Subscribe to our newsletter for the latest insights, events, and opportunities.</p>
          <form class="flex flex-col sm:flex-row gap-4 max-w-lg mx-auto">
            <input type="email" placeholder="Enter your email" class="flex-1 px-6 py-4 bg-white/10 border border-white/20 rounded-full text-white font-['Jost'] placeholder:text-white/40 focus:outline-none focus:border-[#B8963E]">
            <button type="submit" class="px-8 py-4 bg-[#B8963E] text-white font-['Jost'] font-medium rounded-full hover:bg-[#B8963E]/90 transition-all whitespace-nowrap">
              Subscribe
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
