---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us">
  <TopBar />
  <Navbar />
  <main>
    <!-- Contact Hero -->
    <section class="relative py-32 lg:py-48 bg-[#FAF8F5] overflow-hidden">
      <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(#B8963E 1px, transparent 1px), linear-gradient(90deg, #B8963E 1px, transparent 1px); background-size: 100px 100px;"></div>

      <div class="relative max-w-[1600px] mx-auto px-8 lg:px-16 text-center">
        <div class="flex items-center justify-center gap-4 mb-6">
          <div class="w-12 h-[1px] bg-gradient-to-r from-transparent to-[#B8963E]"></div>
          <span class="text-[#B8963E] text-xs font-medium tracking-[0.3em] uppercase font-['Jost']">Get In Touch</span>
          <div class="w-12 h-[1px] bg-gradient-to-l from-transparent to-[#B8963E]"></div>
        </div>
        <h1 class="font-['Bodoni_Moda'] text-5xl sm:text-6xl lg:text-7xl font-medium text-[#1A1817] leading-[1.1] tracking-tight">
          Contact <span class="text-gold-gradient">Us</span>
        </h1>
        <p class="mt-6 text-lg lg:text-xl text-[#1A1817]/60 max-w-2xl mx-auto font-['Jost']">
          Ready to transform your financial future? Let's start a conversation.
        </p>
      </div>
    </section>

    <!-- Contact Form & Info -->
    <section class="py-24 lg:py-32 bg-white">
      <div class="max-w-[1600px] mx-auto px-8 lg:px-16">
        <div class="grid lg:grid-cols-2 gap-16 lg:gap-24">
          <!-- Contact Form -->
          <div class="reveal-left">
            <h2 class="font-['Bodoni_Moda'] text-3xl lg:text-4xl font-medium text-[#1A1817] mb-8">Send us a Message</h2>
            <form class="space-y-6">
              <div class="grid sm:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-['Jost'] text-[#1A1817]/60 mb-2">Full Name</label>
                  <input type="text" class="w-full px-5 py-4 bg-[#FAF8F5] border border-[#1A1817]/10 rounded-xl focus:border-[#B8963E] focus:outline-none focus:ring-2 focus:ring-[#B8963E]/20 transition-all font-['Jost']" placeholder="Your name">
                </div>
                <div>
                  <label class="block text-sm font-['Jost'] text-[#1A1817]/60 mb-2">Email Address</label>
                  <input type="email" class="w-full px-5 py-4 bg-[#FAF8F5] border border-[#1A1817]/10 rounded-xl focus:border-[#B8963E] focus:outline-none focus:ring-2 focus:ring-[#B8963E]/20 transition-all font-['Jost']" placeholder="your@email.com">
                </div>
              </div>
              <div>
                <label class="block text-sm font-['Jost'] text-[#1A1817]/60 mb-2">Phone Number</label>
                <input type="tel" class="w-full px-5 py-4 bg-[#FAF8F5] border border-[#1A1817]/10 rounded-xl focus:border-[#B8963E] focus:outline-none focus:ring-2 focus:ring-[#B8963E]/20 transition-all font-['Jost']" placeholder="+91 XXXXX XXXXX">
              </div>
              <div>
                <label class="block text-sm font-['Jost'] text-[#1A1817]/60 mb-2">Subject</label>
                <select class="w-full px-5 py-4 bg-[#FAF8F5] border border-[#1A1817]/10 rounded-xl focus:border-[#B8963E] focus:outline-none focus:ring-2 focus:ring-[#B8963E]/20 transition-all font-['Jost']">
                  <option>Select a topic</option>
                  <option>Investment Opportunities</option>
                  <option>Startup Enquiries</option>
                  <option>Partnership</option>
                  <option>Events</option>
                  <option>Other</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-['Jost'] text-[#1A1817]/60 mb-2">Message</label>
                <textarea rows="5" class="w-full px-5 py-4 bg-[#FAF8F5] border border-[#1A1817]/10 rounded-xl focus:border-[#B8963E] focus:outline-none focus:ring-2 focus:ring-[#B8963E]/20 transition-all font-['Jost'] resize-none" placeholder="Tell us how we can help..."></textarea>
              </div>
              <button type="submit" class="w-full sm:w-auto px-10 py-5 bg-[#1A1817] text-white font-['Jost'] font-medium tracking-wide rounded-full hover:bg-[#1A1817]/90 transition-all duration-300 hover:shadow-luxe">
                Send Message
              </button>
            </form>
          </div>

          <!-- Contact Info -->
          <div class="reveal-right">
            <h2 class="font-['Bodoni_Moda'] text-3xl lg:text-4xl font-medium text-[#1A1817] mb-8">Get in Touch</h2>
            <div class="space-y-8">
              <div class="flex items-start gap-5">
                <div class="w-14 h-14 bg-[#B8963E]/10 rounded-2xl flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#B8963E]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-['Jost'] font-medium text-[#1A1817] mb-1">Office Address</h3>
                  <p class="text-[#1A1817]/60 font-['Jost']">C-201-202, Sector 74, Mohali, Punjab</p>
                </div>
              </div>

              <div class="flex items-start gap-5">
                <div class="w-14 h-14 bg-[#B8963E]/10 rounded-2xl flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#B8963E]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-['Jost'] font-medium text-[#1A1817] mb-1">Email Address</h3>
                  <p class="text-[#1A1817]/60 font-['Jost']">info@punjabangelsnetwork.com</p>
                </div>
              </div>

              <div class="flex items-start gap-5">
                <div class="w-14 h-14 bg-[#B8963E]/10 rounded-2xl flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#B8963E]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-['Jost'] font-medium text-[#1A1817] mb-1">Phone</h3>
                  <p class="text-[#1A1817]/60 font-['Jost']">+91 XXX XXX XXXX</p>
                </div>
              </div>

              <!-- WhatsApp Groups -->
              <div class="pt-8 border-t border-[#1A1817]/10">
                <h3 class="font-['Jost'] font-medium text-[#1A1817] mb-4">Join Our WhatsApp Groups</h3>
                <div class="flex flex-wrap gap-4">
                  <a href="https://chat.whatsapp.com/DhJwGL7p6087eeVUQCQcIM" target="_blank" class="inline-flex items-center gap-2 px-5 py-3 bg-[#25D366]/10 text-[#25D366] font-['Jost'] text-sm font-medium rounded-full hover:bg-[#25D366]/20 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    Group 1
                  </a>
                  <a href="https://chat.whatsapp.com/D4PR0JMtulMI86aOowg67v" target="_blank" class="inline-flex items-center gap-2 px-5 py-3 bg-[#25D366]/10 text-[#25D366] font-['Jost'] text-sm font-medium rounded-full hover:bg-[#25D366]/20 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    Group 2
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
