---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map(event => ({
    params: { slug: event.id },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);
---

<Layout title={event.data.title}>
  <TopBar />
  <Navbar />
  <main>
    <!-- Event Hero -->
    <section class="relative py-32 lg:py-48 bg-[#FAF8F5] overflow-hidden">
      <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(#B8963E 1px, transparent 1px), linear-gradient(90deg, #B8963E 1px, transparent 1px); background-size: 100px 100px;"></div>

      <div class="relative max-w-[1600px] mx-auto px-8 lg:px-16">
        <!-- Breadcrumb -->
        <nav class="mb-8">
          <ol class="flex items-center gap-2 text-sm font-['Jost'] text-[#1A1817]/50">
            <li><a href="/" class="hover:text-[#B8963E] transition-colors">Home</a></li>
            <li>/</li>
            <li><a href="/events" class="hover:text-[#B8963E] transition-colors">Events</a></li>
            <li>/</li>
            <li class="text-[#1A1817]/80">{event.data.title}</li>
          </ol>
        </nav>

        <div class="max-w-4xl">
          {event.data.category && (
            <span class="inline-block px-4 py-1.5 bg-[#B8963E]/10 text-[#B8963E] text-xs font-medium tracking-wide rounded-full font-['Jost'] mb-6">
              {event.data.category}
            </span>
          )}
          <h1 class="font-['Bodoni_Moda'] text-4xl sm:text-5xl lg:text-6xl font-medium text-[#1A1817] leading-[1.1] tracking-tight">
            {event.data.title}
          </h1>

          <div class="mt-8 flex flex-wrap items-center gap-6 text-[#1A1817]/60 font-['Jost']">
            {event.data.date && (
              <span class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#B8963E]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                </svg>
                {event.data.date}
              </span>
            )}
            {event.data.location && (
              <span class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#B8963E]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
                {event.data.location}
              </span>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- Event Content -->
    <section class="py-24 lg:py-32 bg-white">
      <div class="max-w-[1600px] mx-auto px-8 lg:px-16">
        <div class="grid lg:grid-cols-3 gap-12 lg:gap-16">
          <!-- Main Content -->
          <div class="lg:col-span-2">
            <!-- Event Image -->
            {event.data.image && (
              <div class="mb-12 rounded-3xl overflow-hidden">
                <img src={event.data.image} alt={event.data.title} class="w-full h-auto" />
              </div>
            )}

            <!-- Event Description -->
            <div class="prose prose-lg max-w-none">
              <div class="font-['Jost'] text-[#1A1817]/70 leading-[1.9] space-y-6">
                <Content />
              </div>
            </div>
          </div>

          <!-- Sidebar -->
          <div class="space-y-8">
            <!-- Event Details Card -->
            <div class="bg-[#FAF8F5] rounded-3xl p-8 border border-[#1A1817]/5">
              <h3 class="font-['Bodoni_Moda'] text-2xl font-medium text-[#1A1817] mb-6">Event Details</h3>

              <dl class="space-y-5">
                {event.data.date && (
                  <div>
                    <dt class="text-xs font-medium tracking-[0.2em] uppercase text-[#1A1817]/40 font-['Jost']">Date</dt>
                    <dd class="mt-1 text-[#1A1817] font-['Jost']">{event.data.date}</dd>
                  </div>
                )}
                {event.data.location && (
                  <div>
                    <dt class="text-xs font-medium tracking-[0.2em] uppercase text-[#1A1817]/40 font-['Jost']">Location</dt>
                    <dd class="mt-1 text-[#1A1817] font-['Jost']">{event.data.location}</dd>
                  </div>
                )}
                {event.data.category && (
                  <div>
                    <dt class="text-xs font-medium tracking-[0.2em] uppercase text-[#1A1817]/40 font-['Jost']">Category</dt>
                    <dd class="mt-1 text-[#1A1817] font-['Jost']">{event.data.category}</dd>
                  </div>
                )}
                {event.data.status && (
                  <div>
                    <dt class="text-xs font-medium tracking-[0.2em] uppercase text-[#1A1817]/40 font-['Jost']">Status</dt>
                    <dd class="mt-1 text-[#1A1817] font-['Jost']">{event.data.status}</dd>
                  </div>
                )}
                {event.data.venue && (
                  <div>
                    <dt class="text-xs font-medium tracking-[0.2em] uppercase text-[#1A1817]/40 font-['Jost']">Venue</dt>
                    <dd class="mt-1 text-[#1A1817] font-['Jost']">{event.data.venue}</dd>
                  </div>
                )}
              </dl>
            </div>

            <!-- Contact Card -->
            <div class="bg-[#1A1817] rounded-3xl p-8 text-white">
              <h3 class="font-['Bodoni_Moda'] text-2xl font-medium mb-6">Get in Touch</h3>
              <p class="text-white/60 font-['Jost'] mb-6">Have questions about this event? Contact us for more information.</p>
              <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 bg-[#B8963E] text-white font-['Jost'] font-medium rounded-full hover:bg-[#B8963E]/90 transition-all">
                <span>Contact Us</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </a>
            </div>

            <!-- Share Card -->
            <div class="bg-[#FAF8F5] rounded-3xl p-8 border border-[#1A1817]/5">
              <h3 class="font-['Bodoni_Moda'] text-2xl font-medium text-[#1A1817] mb-6">Share This Event</h3>
              <div class="flex gap-4">
                <a href="https://twitter.com/intent/tweet?text=Check%20out%20this%20event%20-%20{event.data.title}&url=" target="_blank" class="w-12 h-12 bg-[#1A1817]/5 hover:bg-[#1A1817]/10 rounded-2xl flex items-center justify-center text-[#1A1817]/60 hover:text-[#1A1817] transition-all">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
                <a href="https://www.linkedin.com/shareArticle?mini=true&title={event.data.title}" target="_blank" class="w-12 h-12 bg-[#1A1817]/5 hover:bg-[#1A1817]/10 rounded-2xl flex items-center justify-center text-[#1A1817]/60 hover:text-[#1A1817] transition-all">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
                <a href="https://www.facebook.com/sharer/sharer.php?u=" target="_blank" class="w-12 h-12 bg-[#1A1817]/5 hover:bg-[#1A1817]/10 rounded-2xl flex items-center justify-center text-[#1A1817]/60 hover:text-[#1A1817] transition-all">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
