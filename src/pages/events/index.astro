---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Navbar from '../../components/Navbar.astro';
import Events from '../../components/Events.astro';
import Stats from '../../components/Stats.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const events = await getCollection('events');
---

<Layout title="Events">
  <TopBar />
  <Navbar />
  <main>
    <!-- Events Hero -->
    <section class="relative py-32 lg:py-48 bg-[#FAF8F5] overflow-hidden">
      <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(#B8963E 1px, transparent 1px), linear-gradient(90deg, #B8963E 1px, transparent 1px); background-size: 100px 100px;"></div>

      <div class="relative max-w-[1600px] mx-auto px-8 lg:px-16 text-center">
        <div class="flex items-center justify-center gap-4 mb-6">
          <div class="w-12 h-[1px] bg-gradient-to-r from-transparent to-[#B8963E]"></div>
          <span class="text-[#B8963E] text-xs font-medium tracking-[0.3em] uppercase font-['Jost']">Network</span>
          <div class="w-12 h-[1px] bg-gradient-to-l from-transparent to-[#B8963E]"></div>
        </div>
        <h1 class="font-['Bodoni_Moda'] text-5xl sm:text-6xl lg:text-7xl font-medium text-[#1A1817] leading-[1.1] tracking-tight">
          Our <span class="text-gold-gradient">Events</span>
        </h1>
        <p class="mt-6 text-lg lg:text-xl text-[#1A1817]/60 max-w-2xl mx-auto font-['Jost']">
          Join our events network for success - Weekly, Monthly, Quarterly, and Annual events across India and worldwide.
        </p>
      </div>
    </section>

    <!-- Weekly Events -->
    <section class="py-24 lg:py-32 bg-white">
      <div class="max-w-[1600px] mx-auto px-8 lg:px-16">
        <div class="text-center mb-16">
          <span class="text-[#B8963E] text-xs font-medium tracking-[0.3em] uppercase font-['Jost']">Every Week</span>
          <h2 class="font-['Bodoni_Moda'] text-4xl lg:text-5xl font-medium text-[#1A1817] mt-4">Weekly Events</h2>
          <p class="mt-4 text-[#1A1817]/60 font-['Jost']">Coverage: Tricity - Chandigarh, Panchkula, Mohali</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {events.filter(e => e.data.category === 'Weekly').slice(0, 3).map(event => (
            <a href={`/events/${event.slug}`} class="group block bg-white rounded-2xl overflow-hidden border border-[#1A1817]/5 hover:border-[#B8963E]/20 transition-all duration-500 hover:shadow-luxe hover:-translate-y-1">
              <div class="relative h-48 bg-gradient-to-br from-[#B8963E]/10 to-[#96751C]/10 overflow-hidden">
                {event.data.image ? (
                  <img src={event.data.image} alt={event.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-[#B8963E]/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                    </svg>
                  </div>
                )}
                {event.data.category && (
                  <span class="absolute top-4 left-4 px-3 py-1 bg-[#1A1817]/80 backdrop-blur-sm text-white text-xs font-medium tracking-wide rounded-full font-['Jost']">
                    {event.data.category}
                  </span>
                )}
              </div>
              <div class="p-6">
                <h3 class="font-['Bodoni_Moda'] text-xl font-medium text-[#1A1817] group-hover:text-[#B8963E] transition-colors duration-300 leading-tight">
                  {event.data.title}
                </h3>
                <div class="mt-4 flex items-center gap-4 text-sm text-[#1A1817]/50 font-['Jost']">
                  {event.data.date && (
                    <span class="flex items-center gap-1.5">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                      </svg>
                      {event.data.date}
                    </span>
                  )}
                  {event.data.location && (
                    <span class="flex items-center gap-1.5">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                      </svg>
                      {event.data.location}
                    </span>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

