---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Navbar from '../components/Navbar.astro';
import Stats from '../components/Stats.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Fund Raising">
  <TopBar />
  <Navbar />
  <main>
    <!-- Fund Raising Hero -->
    <section class="relative py-32 lg:py-48 bg-[#FAF8F5] overflow-hidden">
      <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(#B8963E 1px, transparent 1px), linear-gradient(90deg, #B8963E 1px, transparent 1px); background-size: 100px 100px;"></div>

      <div class="relative max-w-[1600px] mx-auto px-8 lg:px-16 text-center">
        <div class="flex items-center justify-center gap-4 mb-6">
          <div class="w-12 h-[1px] bg-gradient-to-r from-transparent to-[#B8963E]"></div>
          <span class="text-[#B8963E] text-xs font-medium tracking-[0.3em] uppercase font-['Jost']">Capital</span>
          <div class="w-12 h-[1px] bg-gradient-to-l from-transparent to-[#B8963E]"></div>
        </div>
        <h1 class="font-['Bodoni_Moda'] text-5xl sm:text-6xl lg:text-7xl font-medium text-[#1A1817] leading-[1.1] tracking-tight">
          Fund <span class="text-gold-gradient">Raising</span>
        </h1>
        <p class="mt-6 text-lg lg:text-xl text-[#1A1817]/60 max-w-2xl mx-auto font-['Jost']">
          Expert guidance on raising capital for your startup from seed to scale.
        </p>
      </div>
    </section>

    <!-- Fund Raising Process -->
    <section class="py-24 lg:py-32 bg-white">
      <div class="max-w-[1600px] mx-auto px-8 lg:px-16">
        <div class="text-center mb-16">
          <h2 class="font-['Bodoni_Moda'] text-4xl lg:text-5xl font-medium text-[#1A1817]">Our Approach</h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="relative">
            <div class="bg-[#FAF8F5] rounded-3xl p-8 border border-[#1A1817]/5 h-full">
              <div class="w-12 h-12 bg-[#B8963E] text-white rounded-full flex items-center justify-center font-['Bodoni_Moda'] text-xl mb-6">1</div>
              <h3 class="font-['Bodoni_Moda'] text-2xl font-medium text-[#1A1817] mb-4">Discovery</h3>
              <p class="text-[#1A1817]/60 font-['Jost']">We understand your business model, market position, and funding requirements.</p>
            </div>
          </div>

          <div class="relative">
            <div class="bg-[#FAF8F5] rounded-3xl p-8 border border-[#1A1817]/5 h-full">
              <div class="w-12 h-12 bg-[#B8963E] text-white rounded-full flex items-center justify-center font-['Bodoni_Moda'] text-xl mb-6">2</div>
              <h3 class="font-['Bodoni_Moda'] text-2xl font-medium text-[#1A1817] mb-4">Preparation</h3>
              <p class="text-[#1A1817]/60 font-['Jost']">We help you craft a compelling pitch, financial projections, and investor materials.</p>
            </div>
          </div>

          <div class="relative">
            <div class="bg-[#FAF8F5] rounded-3xl p-8 border border-[#1A1817]/5 h-full">
              <div class="w-12 h-12 bg-[#B8963E] text-white rounded-full flex items-center justify-center font-['Bodoni_Moda'] text-xl mb-6">3</div>
              <h3 class="font-['Bodoni_Moda'] text-2xl font-medium text-[#1A1817] mb-4">Connection</h3>
              <p class="text-[#1A1817]/60 font-['Jost']">We leverage our network to connect you with suitable investors for your stage.</p>
            </div>
          </div>

          <div class="relative">
            <div class="bg-[#FAF8F5] rounded-3xl p-8 border border-[#1A1817]/5 h-full">
              <div class="w-12 h-12 bg-[#B8963E] text-white rounded-full flex items-center justify-center font-['Bodoni_Moda'] text-xl mb-6">4</div>
              <h3 class="font-['Bodoni_Moda'] text-2xl font-medium text-[#1A1817] mb-4">Support</h3>
              <p class="text-[#1A1817]/60 font-['Jost']">We provide ongoing support through due diligence, negotiations, and closing.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Funding Stages -->
    <section class="py-24 lg:py-32 bg-[#FAF8F5]">
      <div class="max-w-[1600px] mx-auto px-8 lg:px-16">
        <div class="text-center mb-16">
          <h2 class="font-['Bodoni_Moda'] text-4xl lg:text-5xl font-medium text-[#1A1817]">Funding Stages We Support</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-3xl p-8 border border-[#1A1817]/5 hover:border-[#B8963E]/20 transition-all duration-500">
            <h3 class="font-['Bodoni_Moda'] text-2xl font-medium text-[#1A1817] mb-4">Pre-Seed</h3>
            <p class="text-[#1A1817]/60 font-['Jost'] mb-6">Ideation and early development stage funding.</p>
            <ul class="space-y-3 text-[#1A1817]/60 font-['Jost'] text-sm">
              <li class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#B8963E]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                Business Plan Review
              </li>
              <li class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#B8963E]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                MVP Development
              </li>
              <li class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#B8963E]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                Initial Pitch Training
              </li>
            </ul>
          </div>

          <div class="bg-white rounded-3xl p-8 border border-[#1A1817]/5 hover:border-[#B8963E]/20 transition-all duration-500">
            <h3 class="font-['Bodoni_Moda'] text-2xl font-medium text-[#1A1817] mb-4">Seed</h3>
            <p class="text-[#1A1817]/60 font-['Jost'] mb-6">Product-market fit and initial traction funding.</p>
            <ul class="space-y-3 text-[#1A1817]/60 font-['Jost'] text-sm">
              <li class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#B8963E]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                Investor introductions
              </li>
              <li class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#B8963E]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                Due Diligence Support
              </li>
              <li class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#B8963E]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                Term Sheet Guidance
              </li>
            </ul>
          </div>

          <div class="bg-white rounded-3xl p-8 border border-[#1A1817]/5 hover:border-[#B8963E]/20 transition-all duration-500">
            <h3 class="font-['Bodoni_Moda'] text-2xl font-medium text-[#1A1817] mb-4">Series A+</h3>
            <p class="text-[#1A1817]/60 font-['Jost'] mb-6">Scale-up and expansion funding.</p>
            <ul class="space-y-3 text-[#1A1817]/60 font-['Jost'] text-sm">
              <li class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#B8963E]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                Institutional Investors
              </li>
              <li class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#B8963E]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                Corporate Investors
              </li>
              <li class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#B8963E]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                Strategic Partnerships
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <Stats />

    <!-- CTA -->
    <section class="py-24 lg:py-32 bg-[#1A1817]">
      <div class="max-w-[1600px] mx-auto px-8 lg:px-16 text-center">
        <h2 class="font-['Bodoni_Moda'] text-4xl lg:text-5xl font-medium text-white mb-6">Ready to Raise Capital?</h2>
        <p class="text-white/60 font-['Jost'] text-lg mb-10 max-w-2xl mx-auto">Get expert guidance on your fund-raising journey.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/apply" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#B8963E] text-white font-['Jost'] font-medium rounded-full hover:bg-[#B8963E]/90 transition-all">
            <span>Apply Now</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
          <a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/20 text-white font-['Jost'] font-medium rounded-full hover:bg-white/10 transition-all">
            <span>Schedule a Call</span>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
