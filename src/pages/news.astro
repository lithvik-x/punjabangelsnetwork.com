---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="News & Media">
  <TopBar />
  <Navbar />
  <main>
    <!-- News Hero -->
    <section class="relative py-32 lg:py-48 bg-[#FAF8F5] overflow-hidden">
      <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(#B8963E 1px, transparent 1px), linear-gradient(90deg, #B8963E 1px, transparent 1px); background-size: 100px 100px;"></div>

      <div class="relative max-w-[1600px] mx-auto px-8 lg:px-16 text-center">
        <div class="flex items-center justify-center gap-4 mb-6">
          <div class="w-12 h-[1px] bg-gradient-to-r from-transparent to-[#B8963E]"></div>
          <span class="text-[#B8963E] text-xs font-medium tracking-[0.3em] uppercase font-['Jost']">Updates</span>
          <div class="w-12 h-[1px] bg-gradient-to-l from-transparent to-[#B8963E]"></div>
        </div>
        <h1 class="font-['Bodoni_Moda'] text-5xl sm:text-6xl lg:text-7xl font-medium text-[#1A1817] leading-[1.1] tracking-tight">
          News & <span class="text-gold-gradient">Media</span>
        </h1>
        <p class="mt-6 text-lg lg:text-xl text-[#1A1817]/60 max-w-2xl mx-auto font-['Jost']">
          The latest updates, press releases, and media coverage of Punjab Angels Network.
        </p>
      </div>
    </section>

    <!-- Press Releases -->
    <section class="py-24 lg:py-32 bg-white">
      <div class="max-w-[1600px] mx-auto px-8 lg:px-16">
        <div class="text-center mb-16">
          <h2 class="font-['Bodoni_Moda'] text-4xl lg:text-5xl font-medium text-[#1A1817]">Press Releases</h2>
        </div>

        <div class="space-y-8">
          <!-- Press Item 1 -->
          <article class="bg-[#FAF8F5] rounded-3xl p-8 border border-[#1A1817]/5 hover:border-[#B8963E]/20 transition-all duration-500">
            <div class="flex flex-col md:flex-row md:items-center gap-6">
              <div class="w-full md:w-48 h-32 bg-[#B8963E]/10 rounded-2xl flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-[#B8963E]/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
              </div>
              <div class="flex-1">
                <div class="flex items-center gap-3 text-xs text-[#1A1817]/40 font-['Jost'] mb-3">
                  <span>January 15, 2026</span>
                  <span class="w-1 h-1 bg-[#1A1817]/20 rounded-full"></span>
                  <span>Press Release</span>
                </div>
                <h3 class="font-['Bodoni_Moda'] text-xl font-medium text-[#1A1817] mb-3 hover:text-[#B8963E] transition-colors cursor-pointer">
                  Punjab Angels Network Announces Transform 6.0 - India's Largest Startup Summit
                </h3>
                <p class="text-[#1A1817]/60 font-['Jost'] text-sm leading-relaxed">
                  The annual flagship event brings together 500+ startups, 200+ investors, and industry leaders for a day of networking and knowledge sharing.
                </p>
              </div>
              <a href="#" class="inline-flex items-center gap-2 px-6 py-3 bg-[#1A1817] text-white text-sm font-['Jost'] rounded-full hover:bg-[#1A1817]/90 transition-all whitespace-nowrap">
                <span>Read More</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </article>

          <!-- Press Item 2 -->
          <article class="bg-[#FAF8F5] rounded-3xl p-8 border border-[#1A1817]/5 hover:border-[#B8963E]/20 transition-all duration-500">
            <div class="flex flex-col md:flex-row md:items-center gap-6">
              <div class="w-full md:w-48 h-32 bg-[#B8963E]/10 rounded-2xl flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-[#B8963E]/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
              </div>
              <div class="flex-1">
                <div class="flex items-center gap-3 text-xs text-[#1A1817]/40 font-['Jost'] mb-3">
                  <span>December 5, 2025</span>
                  <span class="w-1 h-1 bg-[#1A1817]/20 rounded-full"></span>
                  <span>Media Coverage</span>
                </div>
                <h3 class="font-['Bodoni_Moda'] text-xl font-medium text-[#1A1817] mb-3 hover:text-[#B8963E] transition-colors cursor-pointer">
                  Punjab Angels Network Featured in Economic Times for Driving Startup Growth
                </h3>
                <p class="text-[#1A1817]/60 font-['Jost'] text-sm leading-relaxed">
                  Leading business newspaper highlights PAN's contribution to nurturing over 50 startups and Rs 100+ Crores in funding.
                </p>
              </div>
              <a href="#" class="inline-flex items-center gap-2 px-6 py-3 bg-[#1A1817] text-white text-sm font-['Jost'] rounded-full hover:bg-[#1A1817]/90 transition-all whitespace-nowrap">
                <span>Read More</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </article>

          <!-- Press Item 3 -->
          <article class="bg-[#FAF8F5] rounded-3xl p-8 border border-[#1A1817]/5 hover:border-[#B8963E]/20 transition-all duration-500">
            <div class="flex flex-col md:flex-row md:items-center gap-6">
              <div class="w-full md:w-48 h-32 bg-[#B8963E]/10 rounded-2xl flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-[#B8963E]/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
              </div>
              <div class="flex-1">
                <div class="flex items-center gap-3 text-xs text-[#1A1817]/40 font-['Jost'] mb-3">
                  <span>November 20, 2025</span>
                  <span class="w-1 h-1 bg-[#1A1817]/20 rounded-full"></span>
                  <span>Partnership</span>
                </div>
                <h3 class="font-['Bodoni_Moda'] text-xl font-medium text-[#1A1817] mb-3 hover:text-[#B8963E] transition-colors cursor-pointer">
                  PAN Partners with Leading VC Firms to Launch North India's First Angel Syndicate
                </h3>
                <p class="text-[#1A1817]/60 font-['Jost'] text-sm leading-relaxed">
                  Strategic partnership aims to channel Rs 500+ Crores into promising startups across sectors.
                </p>
              </div>
              <a href="#" class="inline-flex items-center gap-2 px-6 py-3 bg-[#1A1817] text-white text-sm font-['Jost'] rounded-full hover:bg-[#1A1817]/90 transition-all whitespace-nowrap">
                <span>Read More</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- Media Kit -->
    <section class="py-24 lg:py-32 bg-[#FAF8F5]">
      <div class="max-w-[1600px] mx-auto px-8 lg:px-16">
        <div class="bg-white rounded-3xl p-8 lg:p-16 border border-[#1A1817]/5">
          <div class="grid lg:grid-cols-2 gap-12 items-center">
            <div>
              <span class="text-[#B8963E] text-xs font-medium tracking-[0.3em] uppercase font-['Jost']">Resources</span>
              <h2 class="font-['Bodoni_Moda'] text-3xl lg:text-4xl font-medium text-[#1A1817] mt-4 mb-6">Media Kit</h2>
              <p class="text-[#1A1817]/60 font-['Jost'] leading-relaxed mb-8">
                Access our press kit containing high-resolution logos, brand guidelines, leadership photos, and company information for media publications.
              </p>
              <a href="#" class="inline-flex items-center gap-2 px-8 py-4 bg-[#1A1817] text-white font-['Jost'] font-medium rounded-full hover:bg-[#1A1817]/90 transition-all">
                <span>Download Media Kit</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" />
                </svg>
              </a>
            </div>
            <div class="bg-[#FAF8F5] rounded-2xl p-8 border border-[#1A1817]/5">
              <h3 class="font-['Bodoni_Moda'] text-xl font-medium text-[#1A1817] mb-6">Press Contact</h3>
              <div class="space-y-4">
                <div class="flex items-center gap-4">
                  <div class="w-12 h-12 bg-[#B8963E]/10 rounded-xl flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#B8963E]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                    </svg>
                  </div>
                  <div>
                    <p class="font-['Jost'] font-medium text-[#1A1817]">info@punjabangelsnetwork.com</p>
                    <p class="text-[#1A1817]/50 text-sm font-['Jost']">Media Inquiries</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
