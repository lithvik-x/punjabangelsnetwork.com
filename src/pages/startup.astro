---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Navbar from '../components/Navbar.astro';
import Startups from '../components/Startups.astro';
import Services from '../components/Services.astro';
import Stats from '../components/Stats.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="For Startups">
  <TopBar />
  <Navbar />
  <main>
    <!-- Startup Hero -->
    <section class="relative py-32 lg:py-48 bg-[#FAF8F5] overflow-hidden">
      <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(#B8963E 1px, transparent 1px), linear-gradient(90deg, #B8963E 1px, transparent 1px); background-size: 100px 100px;"></div>

      <div class="relative max-w-[1600px] mx-auto px-8 lg:px-16 text-center">
        <div class="flex items-center justify-center gap-4 mb-6">
          <div class="w-12 h-[1px] bg-gradient-to-r from-transparent to-[#B8963E]"></div>
          <span class="text-[#B8963E] text-xs font-medium tracking-[0.3em] uppercase font-['Jost']">Launch</span>
          <div class="w-12 h-[1px] bg-gradient-to-l from-transparent to-[#B8963E]"></div>
        </div>
        <h1 class="font-['Bodoni_Moda'] text-5xl sm:text-6xl lg:text-7xl font-medium text-[#1A1817] leading-[1.1] tracking-tight">
          For <span class="text-gold-gradient">Startups</span>
        </h1>
        <p class="mt-6 text-lg lg:text-xl text-[#1A1817]/60 max-w-2xl mx-auto font-['Jost']">
          Transform your visionary ideas into successful businesses with mentorship, funding, and ecosystem support.
        </p>
      </div>
    </section>

    <Services />
    <Startups />
    <Stats />

    <!-- Startup Benefits -->
    <section class="py-24 lg:py-32 bg-white">
      <div class="max-w-[1600px] mx-auto px-8 lg:px-16">
        <div class="text-center mb-16">
          <h2 class="font-['Bodoni_Moda'] text-4xl lg:text-5xl font-medium text-[#1A1817]">Why Choose Us?</h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="text-center">
            <div class="w-20 h-20 bg-[#B8963E]/10 rounded-full flex items-center justify-center mx-auto mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-[#B8963E]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
              </svg>
            </div>
            <h3 class="font-['Bodoni_Moda'] text-xl font-medium text-[#1A1817] mb-3">Expert Mentorship</h3>
            <p class="text-[#1A1817]/60 font-['Jost'] text-sm">Learn from industry veterans who have scaled successful businesses.</p>
          </div>

          <div class="text-center">
            <div class="w-20 h-20 bg-[#B8963E]/10 rounded-full flex items-center justify-center mx-auto mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-[#B8963E]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H15V10.5z" />
              </svg>
            </div>
            <h3 class="font-['Bodoni_Moda'] text-xl font-medium text-[#1A1817] mb-3">Funding Access</h3>
            <p class="text-[#1A1817]/60 font-['Jost'] text-sm">Connect with angel investors ready to fund promising ventures.</p>
          </div>

          <div class="text-center">
            <div class="w-20 h-20 bg-[#B8963E]/10 rounded-full flex items-center justify-center mx-auto mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-[#B8963E]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
              </svg>
            </div>
            <h3 class="font-['Bodoni_Moda'] text-xl font-medium text-[#1A1817] mb-3">Network Growth</h3>
            <p class="text-[#1A1817]/60 font-['Jost'] text-sm">Join a community of founders, investors, and industry experts.</p>
          </div>

          <div class="text-center">
            <div class="w-20 h-20 bg-[#B8963E]/10 rounded-full flex items-center justify-center mx-auto mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-[#B8963E]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
              </svg>
            </div>
            <h3 class="font-['Bodoni_Moda'] text-xl font-medium text-[#1A1817] mb-3">Learning Resources</h3>
            <p class="text-[#1A1817]/60 font-['Jost'] text-sm">Access masterclasses, workshops, and educational content.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 lg:py-32 bg-[#1A1817]">
      <div class="max-w-[1600px] mx-auto px-8 lg:px-16 text-center">
        <h2 class="font-['Bodoni_Moda'] text-4xl lg:text-5xl font-medium text-white mb-6">Ready to Scale Your Startup?</h2>
        <p class="text-white/60 font-['Jost'] text-lg mb-10 max-w-2xl mx-auto">Join our ecosystem and get the support you need to grow.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/apply" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#B8963E] text-white font-['Jost'] font-medium rounded-full hover:bg-[#B8963E]/90 transition-all">
            <span>Apply Now</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
          <a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/20 text-white font-['Jost'] font-medium rounded-full hover:bg-white/10 transition-all">
            <span>Talk to Us</span>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
